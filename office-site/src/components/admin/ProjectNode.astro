---
interface Props {
  project: {
    id: string;
    name: string;
    hourlyRate: number;
    currency: string;
    status: string;
  };
}

const { project: p } = Astro.props;
---

<div class="glass p-6 rounded-2xl flex flex-col md:flex-row justify-between items-start md:items-center group hover:bg-white/[0.04] transition-all duration-500 border-l-4 border-l-[#00ff9f]/30 hover:border-l-[#00ff9f] relative overflow-hidden">
  <!-- Subtle grid background -->
  <div class="absolute inset-0 opacity-5 group-hover:opacity-10 transition-opacity pointer-events-none bg-[radial-gradient(#00ff9f_1px,transparent_1px)] [background-size:20px_20px]"></div>

  <div class="space-y-4 relative z-10">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <span class="w-1.5 h-1.5 rounded-full bg-[#00ff9f] group-hover:animate-ping"></span>
        <h4 class="font-bold text-lg tracking-wider text-white group-hover:text-[#00ff9f] transition-colors uppercase font-heading">{p.name}</h4>
      </div>
      <div class="flex items-center gap-4">
        <p class="text-[9px] text-white/40 uppercase tracking-[0.2em] font-bold">СТАВКА: <span class="text-[#00ff9f] font-mono">{p.hourlyRate}</span> {p.currency}</p>
        <div class="w-1 h-1 rounded-full bg-white/20"></div>
        <div class="flex items-center gap-1.5">
            <span class="text-[9px] text-white/40 uppercase tracking-[0.2em] font-bold">РЕЖИМ:</span>
            <span class={`text-[9px] font-black tracking-widest uppercase ${p.status === 'active' ? 'text-[#00ff9f]' : 'text-[#ff00ff]/60'}`}>
              {p.status === 'active' ? 'АКТИВЕН' : p.status === 'paused' ? 'ПАУЗА' : 'ЗАВЕРШЕН'}
            </span>
        </div>
      </div>
    </div>
    <a href={`/view/${p.id}`} target="_blank" class="group/link flex items-center gap-3 text-[9px] text-[#ff00ff] font-black uppercase tracking-[0.3em] hover:text-white transition-all">
      <span class="p-1 px-2 border border-[#ff00ff]/20 bg-[#ff00ff]/5 rounded group-hover/link:bg-[#ff00ff] group-hover/link:text-white transition-all">
        ИССЛЕДОВАТЬ_УЗЕЛ_ИНТЕРФЕЙСА
      </span>
      <span class="inline-block transform group-hover/link:translate-x-1 transition-transform">→</span>
    </a>
  </div>

  <div class="mt-6 md:mt-0 flex items-center gap-6 relative z-10">
      <div class="text-right hidden md:block group-hover:opacity-100 opacity-40 transition-opacity">
          <p class="text-[8px] uppercase text-white/30 tracking-[.4em] font-bold mb-1 italic">UUID_ПОСЛЕДОВАТЕЛЬНОСТЬ</p>
          <p class="text-[10px] font-mono text-[#00ff9f]/80 bg-[#00ff9f]/5 px-2 py-0.5 rounded border border-[#00ff9f]/10">{p.id}</p>
      </div>
      <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-[#00ff9f]/50 group-hover:shadow-[0_0_20px_rgba(0,255,159,0.15)] transition-all overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#00ff9f]/10 to-transparent"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#00ff9f] shadow-[0_0_12px_#00ff9f] relative z-10"></div>
          <div class="absolute w-full h-full border-2 border-white/10 scale-150 rotate-45 group-hover:rotate-90 transition-transform duration-700"></div>
      </div>
  </div>
</div>
