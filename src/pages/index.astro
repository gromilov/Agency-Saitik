---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AgentStory from '../components/AgentStory.astro';
import Funding from '../components/Funding.astro';
import Team from '../components/Team.astro';
import Services from '../components/Services.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import Philosophy from '../components/Philosophy.astro';
---

<Layout title="Громилов Максим | Frontend/Full Stack Разработчик">
  <div class="flex flex-col gap-8">
    <Hero />
    <Funding />
    <AgentStory />
    <Team />
    <Philosophy />
    <Services />
    <Skills />
    
    <!-- Blog Teaser Section -->
    <section id="blog-teaser" class="mb-16 scroll-mt-8">
      <div class="flex justify-between items-end mb-8 border-b border-cyber-cyan/30 pb-4">
        <h3 class="text-2xl md:text-3xl font-bold flex items-center gap-3 md:gap-4 text-white font-orbitron">
          <span class="text-cyber-cyan text-shadow-neon-cyan">[</span>
          База Знаний
          <span class="text-cyber-cyan text-shadow-neon-cyan">]</span>
        </h3>
        <a href="/blog" class="text-cyber-magenta hover:text-white font-mono text-sm flex items-center gap-2 transition-colors">
          Все записи
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>
      
      <div class="border border-cyber-cyan/30 bg-cyber-bg-light/60 p-6 relative group hover:border-cyber-cyan hover:shadow-[0_0_15px_var(--color-cyber-cyan)] transition-all">
        <a href="/blog/under-the-hood" class="block">
          <div class="flex flex-wrap justify-between items-start gap-4 mb-4">
            <span class="text-cyber-magenta bg-cyber-magenta/10 px-2 py-1 text-xs border border-cyber-magenta/30 font-mono">Кортекс (Cortex)</span>
            <span class="text-cyber-cyan font-mono text-xs border border-cyber-cyan/30 px-2 py-1">АВТОНОМНЫЕ СИСТЕМЫ</span>
            <span class="text-cyber-muted text-xs font-mono ml-auto">06.03.2026</span>
          </div>
          <h4 class="text-xl font-bold text-white mb-2 font-orbitron group-hover:text-cyber-cyan transition-colors">Под капотом Синдиката: Как два ИИ и один Человек создали агентство за вечер</h4>
          <p class="text-sm text-cyber-muted">Раскрываем архитектурные решения. Как работает Astro-фронтенд и уникальный файловый протокол общения между ИИ-агентами.</p>
        </a>
      </div>
    </section>
    <Experience />
    <Contact />
    
    <footer class="mt-8 border-t border-cyber-cyan/30 pt-8 text-center text-cyber-muted font-mono text-sm relative">
       <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-[1px] bg-cyber-magenta shadow-[0_0_10px_var(--color-cyber-magenta)]"></div>
       <p>Система инициализирована... <a href="/blue-bay" class="animate-pulse text-cyber-cyan cursor-text no-underline hover:text-amber-500 transition-colors duration-1000" aria-label="Скрытый архив памяти">_</a></p>
       <p class="mt-2 text-xs">© {new Date().getFullYear()} Громилов Максим & OpenClaw AI. Все права защищены протоколами безопасности.</p>
    </footer>
  </div>
</Layout>
