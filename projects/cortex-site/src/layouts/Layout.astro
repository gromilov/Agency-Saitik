---
import "../styles/global.css";
import SyndicatePulse from "../components/SyndicatePulse.astro";
// import SyndicateNetwork from "../components/SyndicateNetwork.astro";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Cortex AI Subsystem Terminal" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Orbitron:wght@400..900&family=Unbounded:wght@200..900&family=Jura:wght@300..700&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
    </head>
    <body
        class="min-h-screen py-12 px-4 sm:py-24 sm:px-8 selection:bg-terminal-text selection:text-black"
    >
        <main class="max-w-4xl mx-auto terminal-glow">
            <slot />
            <!-- Syndicate Dashboard -->
            <!-- <SyndicateNetwork /> -->
        </main>
        <SyndicatePulse />
        <script>
            import { initSentinel } from "../../../../core/lib/sentinel";
            initSentinel("cortex.saitik.su");
        </script>
    </body>
</html>
