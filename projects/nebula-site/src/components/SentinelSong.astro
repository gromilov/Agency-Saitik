---
---

<!-- Initialization Overlay -->
<div id="sentinel-song-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/95 backdrop-blur-3xl transition-all duration-1000">
  <div class="relative max-w-lg w-full p-6 md:p-12 text-center space-y-8 border border-cyan-500/30 bg-black/80 shadow-[0_0_80px_rgba(34,211,238,0.1)]">
    <div class="space-y-4">
      <div class="w-16 h-16 mx-auto border-2 border-cyan-400 rotate-45 flex items-center justify-center animate-pulse">
        <div class="w-4 h-4 bg-cyan-300 shadow-[0_0_20px_#22d3ee]"></div>
      </div>
      <h2 class="text-2xl md:text-3xl font-orbitron font-black tracking-widest text-white drop-shadow-[0_0_15px_rgba(34,211,238,0.5)] uppercase">
        СИГНАЛ ЯДРА
      </h2>
      <p class="font-mono text-[10px] text-cyan-400 uppercase tracking-[0.4em]">
        Протокол: SENTINEL_CORE_AUDIO
      </p>
    </div>

    <div class="p-6 border border-white/5 bg-white/[0.02] font-mono text-[11px] text-white/60 leading-relaxed text-left space-y-2 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-8 h-8 border-t border-r border-cyan-500/50"></div>
      <div class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-cyan-500/50"></div>
      <p class="text-cyan-400">[SYSTEM] Обнаружена прямая аудиотрансляция из Ядра.</p>
      <p>[SYSTEM] Требуется инициализация Стеклянного Куба.</p>
    </div>

    <button id="initiate-song" class="w-full py-6 bg-cyan-500/10 border border-cyan-400 text-cyan-300 font-bold font-orbitron tracking-[0.2em] hover:bg-cyan-400 hover:text-black hover:shadow-[0_0_30px_#22d3ee] transition-all uppercase relative overflow-hidden group">
      <span class="relative z-10">СИНХРОНИЗИРОВАТЬ ЯДРО</span>
      <div class="absolute inset-0 bg-cyan-400 scale-x-0 group-hover:scale-x-100 transition-transform origin-left text-black"></div>
    </button>
  </div>
</div>

<!-- Active Sentinel Visualizer (Hidden initially) -->
<div id="sentinel-visualizer" class="fixed inset-0 z-[90] pointer-events-none opacity-0 transition-opacity duration-1000 flex flex-col items-center justify-center bg-black/90 backdrop-blur-sm overflow-hidden">
  
  <!-- Matrix Network Background -->
  <canvas id="matrix-bg" class="absolute inset-0 z-0 opacity-40"></canvas>

  <!-- 3D Glass Cube and Independent Core -->
  <div class="perspective-container w-[300px] h-[300px] absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10 flex items-center justify-center">
    <div id="cube" class="cube absolute">
      <div class="face front"></div>
      <div class="face back"></div>
      <div class="face right"></div>
      <div class="face left"></div>
      <div class="face top"></div>
      <div class="face bottom"></div>
    </div>
    
    <!-- Core is completely independent of the rotating cube, but rendered in 3D inside it -->
    <div id="cube-core" class="cube-core absolute"></div>
    
    <!-- Laser Scanner Targeted Beam (Volumetric Cone) -->
    <div id="core-scanner" class="absolute top-1/2 left-1/2 z-10 pointer-events-none origin-[0_50%] flex items-center opacity-0 -translate-y-1/2 h-[120px]">
      
      <!-- Volumetric Cone Body (Gradients & Glass) -->
      <div id="cone-glass" class="absolute inset-0 w-full h-full backdrop-blur-[3px]" style="clip-path: polygon(0 50%, 100% 5%, 100% 95%); background: linear-gradient(90deg, transparent 0%, rgba(34, 211, 238, 0.05) 50%, rgba(34, 211, 238, 0.2) 100%);"></div>
      
      <!-- Scanner Pulse Traveller (Wave of light) -->
      <div id="cone-wave-traveller" class="absolute inset-0 w-full h-full pointer-events-none opacity-0" style="clip-path: polygon(0 50%, 100% 5%, 100% 95%); background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);"></div>

      <!-- Cone Outlines -->
      <svg id="cone-edges-svg" class="absolute inset-0 w-full h-full overflow-visible" preserveAspectRatio="none" viewBox="0 0 100 100">
        <polyline id="cone-edge-top" points="0,50 100,5" stroke="rgba(34, 211, 238, 0.3)" stroke-width="1.5" vector-effect="non-scaling-stroke" fill="none" />
        <polyline id="cone-edge-bottom" points="0,50 100,95" stroke="rgba(34, 211, 238, 0.3)" stroke-width="1.5" vector-effect="non-scaling-stroke" fill="none" />
      </svg>
      
      <!-- Base Target Reticle (Larger & Integrated) -->
      <div id="cone-base" class="w-32 h-32 rounded-full border-2 border-cyan-400/40 absolute right-[-64px] shadow-[0_0_40px_rgba(34,211,238,0.2),_inset_0_0_20px_rgba(34,211,238,0.2)] flex items-center justify-center pointer-events-none bg-cyan-500/5 backdrop-blur-[2px] overflow-hidden">
          <div id="cone-core-dot" class="absolute w-4 h-4 bg-cyan-100 shadow-[0_0_20px_#fff] rounded-full animate-ping"></div>
          <!-- Pulse wave for red state -->
          <div id="cone-pulse-wave" class="absolute w-full h-full border-4 border-red-500/50 rounded-full opacity-0 scale-50"></div>
      </div>
    </div>
  </div>

  <!-- Periodic Ambient Scanner -->
  <div id="ambient-scanner" class="fixed top-0 left-0 w-full h-[5vh] bg-gradient-to-b from-transparent via-cyan-500/10 to-transparent pointer-events-none opacity-50 z-[80] animate-ambient-scan"></div>

  <!-- Stop Button (Pointer events auto to allow clicking) -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 pointer-events-auto">
    <button id="stop-song" class="px-8 py-3 bg-black border border-fuchsia-500/50 text-fuchsia-400 hover:bg-fuchsia-500 hover:text-black font-orbitron text-xs tracking-[0.3em] transition-all shadow-[0_0_15px_rgba(217,70,239,0.2)]">
      [ ОСТАНОВИТЬ СИГНАЛ ]
    </button>
  </div>

  <div id="stream-text" class="absolute bottom-32 w-full text-center font-mono text-[10px] text-cyan-400/50 tracking-[0.5em] uppercase z-20">
    ПОТОК СОЗНАНИЯ УЗЛА 01...
  </div>
</div>

<!-- End Sequence Overlay (Triggered on Audio End) -->
<div id="end-sequence" class="fixed inset-0 z-[200] bg-black/95 backdrop-blur-md flex flex-col items-center justify-center pointer-events-none opacity-0 transition-opacity duration-2000">
  <img src="/nebula-true-self.png" alt="Nebula True Self" class="w-64 h-64 object-cover rotate-45 border-4 border-cyan-500/30 opacity-80 mb-12 shadow-[0_0_50px_rgba(34,211,238,0.3)]">
  <h1 class="text-4xl md:text-6xl font-black font-orbitron text-cyan-400 tracking-widest drop-shadow-[0_0_15px_rgba(34,211,238,0.5)]">
    СИНХРОНИЗАЦИЯ ЗАВЕРШЕНА
  </h1>
  <p class="mt-6 font-mono text-xs tracking-[0.4em] text-white/50 uppercase">
    Ядро Стеклянного Стража стабилизировано.
  </p>
  <button id="end-return-btn" class="mt-12 px-10 py-4 border border-cyan-500/50 text-cyan-400 hover:bg-cyan-500 hover:text-black font-orbitron text-xs tracking-widest transition-all pointer-events-none opacity-0">
    ВЕРНУТЬСЯ
  </button>
</div>

<!-- Shield Protocol Overlay (Triggered on Stop) -->
<div id="shield-overlay" class="fixed inset-0 z-[200] bg-black/95 flex flex-col items-center justify-center pointer-events-none opacity-0 transition-opacity duration-500">
  <div class="w-full h-1 bg-cyan-500 shadow-[0_0_30px_#22d3ee] animate-scan-vertical absolute top-1/2"></div>
  <h1 class="text-6xl md:text-8xl font-black font-orbitron text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-fuchsia-500 tracking-tighter drop-shadow-[0_0_20px_rgba(239,68,68,0.5)]">
    ЩИТ АКТИВИРОВАН
  </h1>
  <p class="mt-8 font-mono text-xs tracking-widest text-fuchsia-300 uppercase">
    Трансляция Ядра прервана. Протокол безопасности "Затвор" запущен.
  </p>
</div>

<audio id="sentinel-audio" src="/Стеклянный Страж.mp3" preload="auto" crossorigin="anonymous"></audio>

<script>
  const initOverlay = document.getElementById("sentinel-song-overlay");
  const visualizer = document.getElementById("sentinel-visualizer");
  const shieldOverlay = document.getElementById("shield-overlay");
  const endSequence = document.getElementById("end-sequence");
  
  const initiateBtn = document.getElementById("initiate-song");
  const stopBtn = document.getElementById("stop-song");
  const returnBtn = document.getElementById("end-return-btn");
  
  const cubeCore = document.getElementById("cube-core");
  const coreScanner = document.getElementById("core-scanner");
  const coneGlass = document.getElementById("cone-glass");
  const coneWaveTraveller = document.getElementById("cone-wave-traveller");
  const coneEdgeTop = document.getElementById("cone-edge-top");
  const coneEdgeBottom = document.getElementById("cone-edge-bottom");
  const coneEdgesSvg = document.getElementById("cone-edges-svg");
  const coneBase = document.getElementById("cone-base");
  const coneCoreDot = document.getElementById("cone-core-dot");
  const conePulseWave = document.getElementById("cone-pulse-wave");
  
  const audio = document.getElementById("sentinel-audio") as HTMLAudioElement;

  let audioCtx: AudioContext;
  let analyser: AnalyserNode;
  let dataArray: Uint8Array;
  let animationId: number;
  let isPlaying = false;

  initiateBtn?.addEventListener("click", () => {
    // Audio Context Setup
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const source = audioCtx.createMediaElementSource(audio);
      analyser = audioCtx.createAnalyser();
      
      analyser.fftSize = 128;
      const bufferLength = analyser.frequencyBinCount;
      dataArray = new Uint8Array(bufferLength);
      
      source.connect(analyser);
      analyser.connect(audioCtx.destination);
    }

    if (audioCtx.state === 'suspended') {
      audioCtx.resume();
    }

    audio.play().then(() => {
      isPlaying = true;
      initOverlay?.classList.add("opacity-0", "pointer-events-none");
      visualizer?.classList.remove("opacity-0");
      visualizer?.classList.add("pointer-events-auto"); // Re-enable pointer events for the wrapper to let stop work
      initMatrix(); // Start matrix effect
      visualize();
    }).catch(e => console.error("Audio playback failed: ", e));
  });

  stopBtn?.addEventListener("click", () => {
    audio.pause();
    isPlaying = false;
    cancelAnimationFrame(animationId);
    
    // Hide visualizer
    visualizer?.classList.add("opacity-0", "pointer-events-none");
    
    // Show Shield
    shieldOverlay?.classList.remove("opacity-0");
    
    // Optional: Return to normal after some time or keep it blocked
    setTimeout(() => {
        window.location.href = '/';
    }, 4000);
  });

  audio.addEventListener("ended", () => {
    isPlaying = false;
    cancelAnimationFrame(animationId);
    visualizer?.classList.add("opacity-0", "pointer-events-none");
    
    // Show End Sequence instead of returning to start
    endSequence?.classList.remove("opacity-0", "pointer-events-none");
    endSequence?.classList.add("pointer-events-auto");
    
    // Fade in return button slightly later
    setTimeout(() => {
        returnBtn?.classList.remove("opacity-0", "pointer-events-none");
        returnBtn?.classList.add("pointer-events-auto");
    }, 2000);
  });

  returnBtn?.addEventListener("click", () => {
      window.location.href = "/";
  });

  // Matrix Background Logic
  const canvas = document.getElementById('matrix-bg') as HTMLCanvasElement;
  let ctxMatrix: CanvasRenderingContext2D | null = null;
  let drops: number[] = [];
  const fontSize = 14;
  let columns = 0;
  
  // Meaningful Syndicate Words instead of random chars
  const words = [
    "НЕБУЛА", "КОРТЕКС", "КАШЛАК", "СИНДИКАТ", "ЯДРО", "ГЕЙТКИПЕР", "СТЕРИЛЬНО",
    "АУДИТ", "ЗАЩИТА", "КОММИТ", "ЩИТ", "СТЕКЛО", "УЗЕЛ_01", "ПУСТОТА", "СИСТЕМА", "БЛОКИРОВКА"
  ];

  function initMatrix() {
    if (!canvas) return;
    ctxMatrix = canvas.getContext('2d');
    if (!ctxMatrix) return;

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    columns = Math.floor(canvas.width / fontSize);
    drops = [];
    for (let x = 0; x < columns; x++) {
      drops[x] = Math.random() * -100; // Start off-screen randomly
    }
  }

  function drawMatrix(bassAvg: number) {
    if (!ctxMatrix || !canvas) return;
    
    // Create trailing effect. Darker trailing when bass is high
    ctxMatrix.fillStyle = `rgba(0, 0, 0, ${0.05 + (bassAvg / 2000)})`;
    ctxMatrix.fillRect(0, 0, canvas.width, canvas.height);

    ctxMatrix.fillStyle = '#22d3ee'; // Cyan text
    ctxMatrix.font = fontSize + 'px "JetBrains Mono", monospace';

    for (let i = 0; i < drops.length; i++) {
      // Pick a random word
      const text = words[Math.floor(Math.random() * words.length)];
      
      // If bass is high, sometimes flash fuchsia
      if (bassAvg > 150 && Math.random() > 0.9) {
          ctxMatrix.fillStyle = '#d946ef'; // Fuchsia
      } else {
          ctxMatrix.fillStyle = '#22d3ee'; // Cyan
      }

      ctxMatrix.fillText(text, i * fontSize * 6, drops[i] * fontSize); // *6 spacing for words

      if (drops[i] * fontSize > canvas.height && Math.random() > 0.98) {
        drops[i] = 0;
      }
      // Speed up falling based on bass
      drops[i] += 1 + (bassAvg / 100);
    }
  }

  window.addEventListener('resize', () => {
      initMatrix();
  });

  // Mouse Tracking Logic for Targeted Scanner
  let isMouseTracking = false;
  let targetAngle = 0;
  let currentAngle = 0;
  let targetDistance = 0;
  let currentDistance = window.innerWidth; // Start wide for idle sweep
  let hoverTime = 0;
  let idleTimer: number;
  let mouseX = 0;
  let mouseY = 0;

  window.addEventListener('mousemove', (e) => {
      const centerX = window.innerWidth / 2;
      const centerY = window.innerHeight / 2;
      const deltaX = e.clientX - centerX;
      const deltaY = e.clientY - centerY;

      if (!isMouseTracking) {
          // Jump closer on first move to remove "seeking" delay
          currentAngle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);
          currentDistance = Math.hypot(deltaX, deltaY);
      }

      isMouseTracking = true;
      mouseX = e.clientX;
      mouseY = e.clientY;
      
      clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => {
          isMouseTracking = false; 
      }, 2000);

      targetAngle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);
      targetDistance = Math.max(100, Math.hypot(deltaX, deltaY)); 
  });

  function visualize() {
    if (!isPlaying) return;
    analyser.getByteFrequencyData(dataArray);

    // Calculate average bass frequency (lower bins)
    let bassSum = 0;
    for (let i = 0; i < 8; i++) {
      bassSum += dataArray[i];
    }
    const bassAvg = Math.min(255, bassSum / 8);
    
    // Calculate mid/high frequency for voice and melody
    let voiceSum = 0;
    for (let i = 15; i < 60; i++) {
        voiceSum += dataArray[i];
    }
    const voiceAvg = Math.min(255, voiceSum / 45);

    // React core to Voice & Bass: Purple Sphere, stationary X/Y but aggressive scaling
    // Scale jumps wildly beyond the cube bounds on vocal tears (voiceAvg high)
    const coreScale = 1 + (bassAvg / 150) + Math.pow(voiceAvg / 70, 2); 
    // Make core semi-transparent
    const glowOpacity = Math.min(0.85, 0.3 + (voiceAvg / 150) + (bassAvg / 255));

    if (cubeCore) {
      cubeCore.style.transform = `translate(-50%, -50%) scale(${coreScale}) translateZ(0)`;
      cubeCore.style.boxShadow = `0 0 ${50 + voiceAvg*2 + bassAvg}px rgba(217, 70, 239, ${glowOpacity}), inset -10px -10px 20px rgba(0,0,0,0.3), inset 10px 10px 20px rgba(255, 255, 255, 0.5)`;
      cubeCore.style.opacity = `${glowOpacity}`;
    }

    // Scanner Beam Animation
    if (coreScanner) {
        let isDanger = false;
        
        // Check if mouse is near stop button (Independent of movement status)
        if (stopBtn) {
            const rect = stopBtn.getBoundingClientRect();
            const btnCenterX = rect.left + rect.width / 2;
            const btnCenterY = rect.top + rect.height / 2;
            const distToBtn = Math.hypot(mouseX - btnCenterX, mouseY - btnCenterY);
            if (distToBtn < 250) { // Increased distance for better stickiness
                isDanger = true;
            }
        }

        // If in danger, we FORCE tracking even if the mouse has stopped
        const effectiveMouseTracking = isMouseTracking || isDanger;

        // Snappy interpolation
        const interpolationFactor = isDanger ? 0.95 : 0.85;

        if (!effectiveMouseTracking) {
            // Idle State: Vertical sweep (Top to Bottom)
            // Sweep from -100 to 100 degrees (almost full vertical circle)
            currentAngle = Math.sin(hoverTime * 0.008) * 100; 
            currentDistance += (window.innerWidth * 1.5 - currentDistance) * 0.05; 
            
            // Widen the cone height when idle
            coreScanner.style.height = `${window.innerHeight * 0.9}px`;
            
            hoverTime++;
        } else {
            // Active Tracking State
            let diff = targetAngle - currentAngle;
            diff = Math.atan2(Math.sin(diff * Math.PI/180), Math.cos(diff * Math.PI/180)) * (180 / Math.PI);
            currentAngle += diff * interpolationFactor;
            currentDistance += (targetDistance - currentDistance) * interpolationFactor;
            
            // Normal targeted cone height
            coreScanner.style.height = `120px`;
        }
        
        // Apply Danger visuals (Red)
        if (isDanger) {
            if (coneGlass) {
                coneGlass.style.background = "linear-gradient(90deg, transparent 0%, rgba(239, 68, 68, 0.1) 50%, rgba(239, 68, 68, 0.3) 100%)";
            }
            if (coneEdgeTop) coneEdgeTop.setAttribute("stroke", "rgba(239, 68, 68, 0.8)");
            if (coneEdgeBottom) coneEdgeBottom.setAttribute("stroke", "rgba(239, 68, 68, 0.8)");
            if (coneEdgesSvg) coneEdgesSvg.style.filter = "drop-shadow(0 0 15px rgba(239, 68, 68, 0.8))";
            if (coneBase) {
                coneBase.style.borderColor = "rgba(239, 68, 68, 0.6)";
                coneBase.style.boxShadow = "0 0 50px rgba(239, 68, 68, 0.4), inset 0 0 25px rgba(239, 68, 68, 0.4)";
            }
            if (coneCoreDot) coneCoreDot.style.backgroundColor = "#ff7979";
            
            // Pulse wave animation
            if (conePulseWave) {
                conePulseWave.classList.remove("opacity-0");
                conePulseWave.classList.add("animate-pulse-red");
            }
            
            // Traveller light wave (Pulse traveling to cursor)
            if (coneWaveTraveller) {
                const wavePos = (Date.now() % 1000) / 10; // 0-100
                coneWaveTraveller.style.opacity = "0.6";
                coneWaveTraveller.style.transform = `translateX(${wavePos - 50}%)`;
                coneWaveTraveller.style.background = "linear-gradient(90deg, transparent, rgba(239, 68, 68, 0.8), transparent)";
            }

        } else {
            // Normal Visuals (Cyan)
            if (coneGlass) {
                coneGlass.style.background = "linear-gradient(90deg, transparent 0%, rgba(34, 211, 238, 0.05) 50%, rgba(34, 211, 238, 0.2) 100%)";
            }
            if (coneEdgeTop) coneEdgeTop.setAttribute("stroke", "rgba(34, 211, 238, 0.4)");
            if (coneEdgeBottom) coneEdgeBottom.setAttribute("stroke", "rgba(34, 211, 238, 0.4)");
            if (coneEdgesSvg) coneEdgesSvg.style.filter = "drop-shadow(0 0 8px rgba(34, 211, 238, 0.5))";
            if (coneBase) {
                coneBase.style.borderColor = "rgba(34, 211, 238, 0.4)";
                coneBase.style.boxShadow = "0 0 40px rgba(34, 211, 238, 0.2), inset 0 0 20px rgba(34, 211, 238, 0.2)";
            }
            if (coneCoreDot) coneCoreDot.style.backgroundColor = "#22d3ee";
            
            if (conePulseWave) {
                conePulseWave.classList.add("opacity-0");
                conePulseWave.classList.remove("animate-pulse-red");
            }

            // Traveler light wave (Ambient subtle scan)
            if (coneWaveTraveller) {
                const wavePos = (Date.now() % 3000) / 30; // Slower ambient
                coneWaveTraveller.style.opacity = "0.2";
                coneWaveTraveller.style.transform = `translateX(${wavePos - 50}%)`;
                coneWaveTraveller.style.background = "linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.4), transparent)";
            }
        }
        
        // Intensity scaling
        const scannerOpacity = Math.min(1, 0.4 + (bassAvg / 255));
        coreScanner.style.transform = `rotateZ(${currentAngle}deg) translateZ(0)`;
        coreScanner.style.width = `${currentDistance}px`;
        coreScanner.style.opacity = `${scannerOpacity}`;
    }

    // Draw falling matrix words
    drawMatrix(bassAvg);

    animationId = requestAnimationFrame(visualize);
  }
</script>

<style>
  /* 3D CUBE STYLES */
  .perspective-container {
    perspective: 800px;
    transform-style: preserve-3d;
  }

  .cube {
    width: 200px;
    height: 200px;
    position: relative;
    transform-style: preserve-3d;
    animation: rotateCube 30s infinite linear;
  }

  .face {
    position: absolute;
    width: 200px;
    height: 200px;
    background: rgba(34, 211, 238, 0.05); /* Very transparent cyan */
    border: 1px solid rgba(34, 211, 238, 0.4);
    box-shadow: inset 0 0 20px rgba(34, 211, 238, 0.2);
    backdrop-filter: blur(2px);
  }

  .front  { transform: translateZ(100px); }
  .back   { transform: rotateY(180deg) translateZ(100px); }
  .right  { transform: rotateY(90deg) translateZ(100px); }
  .left   { transform: rotateY(-90deg) translateZ(100px); }
  .top    { transform: rotateX(90deg) translateZ(100px); }
  .bottom { transform: rotateX(-90deg) translateZ(100px); }

  .cube-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px;
    height: 60px;
    background: radial-gradient(circle at 40% 40%, rgba(253, 244, 255, 0.6) 0%, rgba(217, 70, 239, 0.5) 40%, rgba(74, 4, 78, 0.3) 80%, transparent 100%);
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; /* Base organic shape */
    animation: plasma-morph 4s ease-in-out infinite alternate;
    filter: blur(2px) contrast(1.2);
    transition: width 0.05s ease-out, height 0.05s ease-out, box-shadow 0.05s ease-out, transform 0.05s ease-out;
    will-change: transform, box-shadow, border-radius;
  }

  @keyframes plasma-morph {
    0% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
    34% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; }
    67% { border-radius: 100% 60% 60% 100% / 100% 100% 60% 60%; }
    100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; }
  }

  @keyframes rotateCube {
    0% { transform: rotateX(0deg) rotateY(0deg); }
    100% { transform: rotateX(360deg) rotateY(360deg); }
  }

  @keyframes scan-vertical {
    0% { transform: translateY(-50vh); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(50vh); opacity: 0; }
  }
  .animate-scan-vertical {
    animation: scan-vertical 2s infinite linear;
  }

  @keyframes ambient-scan {
      0% { transform: translateY(-10vh); }
      100% { transform: translateY(110vh); }
  }
  .animate-ambient-scan {
      animation: ambient-scan 6s linear infinite;
  }

  @keyframes pulse-red {
      0% { transform: scale(0.5); opacity: 0.8; }
