---
import '../styles/global.css';
import SyndicatePulse from '../components/SyndicatePulse.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Nebula - Security Guardian" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Orbitron:wght@400..900&family=Unbounded:wght@200..900&family=Jura:wght@300..700&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="star-field overflow-hidden">
            <slot name="background" />
        </div>
		<main class="relative z-10 flex flex-col items-center justify-center min-h-screen p-4">
			<slot />
		</main>
		<SyndicatePulse />
	</body>
</html>
