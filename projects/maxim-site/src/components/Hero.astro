---
import { resumeData } from '../data/resumeData';
---

<header class="py-20 md:py-32 relative overflow-hidden bg-white/[0.02] border border-white/10 rounded-[2.5rem] p-8 md:p-16 backdrop-blur-xl group shadow-2xl shadow-cyber-magenta/5">
  <div class="absolute top-0 right-0 w-96 h-96 bg-cyber-magenta/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/4 group-hover:bg-cyber-magenta/20 transition-all duration-1000"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-cyber-cyan/10 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/4 group-hover:bg-cyber-cyan/20 transition-all duration-1000"></div>
  
  <div class="relative z-10 max-w-4xl">
    <div class="inline-flex items-center gap-3 px-4 py-2 bg-white/5 border border-white/10 text-white/60 text-[10px] font-mono mb-10 uppercase tracking-[0.3em] rounded-full">
      <span class="w-2 h-2 rounded-full bg-cyber-cyan shadow-[0_0_10px_#10b981]"></span>
      Доступен для новых вызовов
    </div>
    
    <h1 class="text-5xl md:text-8xl font-black mb-6 leading-[0.9] tracking-tighter text-white">
      {resumeData.name.split(' ')[0]} <br/>
      <span class="text-cyber-magenta opacity-90">{resumeData.name.split(' ')[1]}</span>
    </h1>
    
    <h2 class="text-2xl md:text-3xl text-cyber-cyan font-bold mb-10 tracking-tight glow-text-cyan transition-all">
      {resumeData.role}
    </h2>
    
    <p class="text-xl md:text-2xl text-cyber-muted leading-relaxed mb-12 max-w-3xl font-medium">
      {resumeData.about}
      <span class="block mt-8 text-sm text-white/30 font-mono tracking-widest uppercase">Локация: {resumeData.location}</span>
    </p>

    <div class="flex flex-wrap gap-6">
      <a href="#contact" class="px-8 py-4 bg-cyber-magenta text-white font-bold rounded-2xl hover:bg-cyber-magenta/90 hover:scale-105 transition-all shadow-lg shadow-cyber-magenta/30">
        Связаться со мной
      </a>
      <a href="#experience" class="px-8 py-4 bg-white/5 border border-white/10 text-white font-bold rounded-2xl hover:bg-white/10 transition-all">
        Изучить опыт
      </a>
    </div>
  </div>
</header>
