---
import { resumeData } from '../data/resumeData';
---

<section id="experience" class="mb-16">
  <h3 class="text-3xl font-bold mb-10 flex items-center gap-4 text-white">
    Ключевой опыт
  </h3>
  
  <div class="space-y-12">
    {resumeData.experience.map((item) => (
      <div class="group relative pl-8 before:absolute before:left-0 before:top-0 before:bottom-0 before:w-px before:bg-white/10 hover:before:bg-cyber-magenta transition-all">
        <div class="absolute -left-1.5 top-2 w-3 h-3 bg-[#0f172a] border-2 border-white/20 rounded-full group-hover:border-cyber-magenta transition-colors shadow-[0_0_10px_rgba(99,102,241,0.5)]"></div>
        
        <div class="flex flex-wrap justify-between items-start gap-4 mb-4">
          <div>
            <h4 class="text-xl font-bold text-white group-hover:text-cyber-magenta transition-colors">{item.title}</h4>
            <p class="text-cyber-muted font-medium mt-1">{item.description}</p>
          </div>
          <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-xs font-mono text-white/40">{item.period}</span>
        </div>
        
        <ul class="space-y-3 text-cyber-muted text-base leading-relaxed max-w-3xl">
          {item.achievements.map((achievement) => (
            <li>• {achievement}</li>
          ))}
        </ul>
        
        {item.tags && (
          <div class="flex flex-wrap gap-2 mt-6">
            {item.tags.map((tag) => (
              <span class="px-2 py-1 bg-cyber-magenta/5 border border-cyber-magenta/20 rounded text-[10px] font-mono text-cyber-magenta uppercase tracking-wider">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</section>

<section class="mb-16">
  <h3 class="text-3xl font-bold mb-10 text-white">Соответствие вакансии</h3>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="p-8 bg-white/[0.03] border border-white/10 rounded-3xl hover:border-white/20 transition-all">
      <h4 class="text-xl font-bold text-cyber-magenta mb-4">Веб-разработка</h4>
      <p class="text-cyber-muted leading-relaxed">Практический опыт использования TypeScript в коммерческих проектах. Фокус на чистоте кода и масштабируемости архитектуры.</p>
    </div>
    
    <div class="p-8 bg-white/[0.03] border border-white/10 rounded-3xl hover:border-white/20 transition-all">
      <h4 class="text-xl font-bold text-cyber-cyan mb-4">Мобильная разработка</h4>
      <p class="text-cyber-muted leading-relaxed">Глубокая экспертиза в мобильном вебе (PWA, Telegram Mini Apps). Готовность к освоению новых инструментов для реализации кросс-платформенных интерфейсов.</p>
    </div>
  </div>
</section>
