---
import { resumeData } from '../data/resumeData';
---

<section id="contact" class="mb-32 scroll-mt-20">
  <div class="p-8 md:p-16 bg-white/[0.02] border border-white/10 rounded-[2.5rem] relative overflow-hidden group">
    <div class="relative z-10">
      <h3 class="text-3xl md:text-5xl font-extrabold mb-6 text-white tracking-tighter">
        Связаться со мной
      </h3>
      <p class="text-xl text-cyber-muted mb-10 max-w-2xl leading-relaxed font-medium">
        {resumeData.contact.message}
      </p>
      
      <div class="flex flex-wrap gap-6">
        <a href={`https://t.me/${resumeData.contact.telegram}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-4 px-10 py-5 bg-cyber-magenta text-white text-lg font-bold rounded-2xl hover:scale-105 transition-all shadow-xl shadow-cyber-magenta/30">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
          Telegram: @{resumeData.contact.telegram}
        </a>
      </div>
    </div>
  </div>
</section>
