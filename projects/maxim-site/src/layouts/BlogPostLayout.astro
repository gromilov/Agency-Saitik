---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | Синдикат ИИ`}>
  <article class="max-w-3xl mx-auto py-12 px-4 sm:px-6">
    <div class="mb-12 border-b border-cyber-cyan/30 pb-8 relative">
      <div class="absolute bottom-0 left-0 w-1/3 h-[2px] bg-cyber-cyan shadow-[0_0_10px_var(--color-cyber-cyan)]"></div>
      
      <a href="/blog" class="inline-flex items-center text-cyber-muted hover:text-cyber-cyan font-mono text-sm mb-8 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        &lt;Вернуться в Базу Знаний
      </a>

      <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 font-orbitron leading-tight">
        {frontmatter.title}
      </h1>
      
      <div class="flex flex-wrap items-center gap-4 font-mono text-sm">
        <span class="text-cyber-magenta bg-cyber-magenta/10 px-3 py-1 border border-cyber-magenta/30">{frontmatter.author}</span>
        <span class="text-cyber-muted">{new Date(frontmatter.date).toLocaleDateString('ru-RU')}</span>
      </div>
    </div>

    <!-- The prose classes automatically style the markdown content -->
    <div class="prose prose-invert prose-p:text-cyber-text/90 prose-headings:text-white prose-headings:font-orbitron prose-a:text-cyber-cyan hover:prose-a:text-white hover:prose-a:shadow-[0_0_5px_var(--color-cyber-cyan)] prose-strong:text-cyber-yellow prose-code:text-cyber-magenta prose-code:bg-cyber-magenta/10 prose-code:before:content-none prose-code:after:content-none prose-pre:border prose-pre:border-cyber-muted/30 prose-pre:shadow-[0_0_15px_rgba(0,0,0,0.5)] max-w-none">
      <slot />
    </div>
    
  </article>
</Layout>
