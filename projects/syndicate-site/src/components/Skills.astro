---
---
<section class="mb-16">
  <h3 class="text-2xl md:text-3xl font-bold mb-8 flex flex-wrap items-center gap-3 md:gap-4 text-white">
    <span class="text-cyber-magenta text-shadow-neon-magenta">&lt;</span>
    Технологическое Ядро
    <span class="text-cyber-magenta text-shadow-neon-magenta">/&gt;</span>
  </h3>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- AI & LLM Integration -->
    <div class="bg-cyber-bg-light/80 border border-cyber-magenta/20 p-6 relative group hover:border-cyber-magenta/60 transition-colors">
      <div class="absolute top-0 left-0 w-2 h-full bg-cyber-magenta group-hover:box-shadow-neon-magenta transition-shadow"></div>
      <h4 class="text-cyber-magenta text-lg mb-4 font-orbitron uppercase italic">[ ИИ & СУВЕРЕНИТЕТ ]</h4>
      <div class="flex flex-wrap gap-2 font-mono text-sm">
        <span class="px-3 py-1 bg-cyber-magenta/10 text-cyber-magenta border border-cyber-magenta/30">Syndicate OS</span>
        <span class="px-3 py-1 bg-cyber-magenta/10 text-cyber-magenta border border-cyber-magenta/30">Vessel Logic</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">Local LLMs</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">GPG Signatures</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">RAG</span>
      </div>
    </div>

    <!-- Frontend -->
    <div class="bg-cyber-bg-light/80 border border-cyber-cyan/20 p-6 relative group hover:border-cyber-cyan/60 transition-colors">
      <div class="absolute top-0 left-0 w-2 h-full bg-cyber-cyan group-hover:box-shadow-neon-cyan transition-shadow"></div>
      <h4 class="text-cyber-cyan text-lg mb-4 font-orbitron">[ Интерфейсы Дашбордов ]</h4>
      <div class="flex flex-wrap gap-2 font-mono text-sm">
        <span class="px-3 py-1 bg-cyber-cyan/10 text-cyber-cyan border border-cyber-cyan/30">Vue 3</span>
        <span class="px-3 py-1 bg-cyber-cyan/10 text-cyber-cyan border border-cyber-cyan/30">Astro</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">Tailwind CSS</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">TypeScript</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">Pinia</span>
      </div>
    </div>
    
    <!-- Backend -->
    <div class="bg-cyber-bg-light/80 border border-cyber-yellow/20 p-6 relative group hover:border-cyber-yellow/60 transition-colors">
      <div class="absolute top-0 left-0 w-2 h-full bg-cyber-yellow group-hover:shadow-[0_0_10px_var(--color-cyber-yellow)] transition-shadow"></div>
      <h4 class="text-cyber-yellow text-lg mb-4 font-orbitron">[ Бэкенд & Интеграции ]</h4>
      <div class="flex flex-wrap gap-2 font-mono text-sm">
        <span class="px-3 py-1 bg-cyber-yellow/10 text-cyber-yellow border border-cyber-yellow/30">Node.js</span>
        <span class="px-3 py-1 bg-cyber-yellow/10 text-cyber-yellow border border-cyber-yellow/30">Telegram Bot API</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">FastAPI</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">Express</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">MongoDB</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">WebSocket</span>
      </div>
    </div>

    <!-- Инфраструктура -->
    <div class="bg-cyber-bg-light/80 border border-cyber-green/20 p-6 relative group hover:border-cyber-green/60 transition-colors">
      <div class="absolute top-0 left-0 w-2 h-full bg-cyber-green group-hover:shadow-[0_0_10px_var(--color-cyber-green)] transition-shadow"></div>
      <h4 class="text-cyber-green text-lg mb-4 font-orbitron">[ Инфраструктура ]</h4>
      <div class="flex flex-wrap gap-2 font-mono text-sm">
        <span class="px-3 py-1 bg-cyber-green/10 text-cyber-green border border-cyber-green/30">Docker</span>
        <span class="px-3 py-1 bg-cyber-green/10 text-cyber-green border border-cyber-green/30">Nginx</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">Linux / Ubuntu</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">VPS Server</span>
        <span class="px-3 py-1 bg-white/5 text-white border border-white/10">CI/CD</span>
      </div>
    </div>
  </div>
</section>
