---
---

<div id="nebula-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/90 backdrop-blur-xl">
  <div class="w-full max-w-lg bg-cyber-bg-light border border-cyber-magenta p-8 relative shadow-[0_0_50px_rgba(255,0,255,0.2)]">
    <!-- Close Button -->
    <button id="close-nebula-modal" class="absolute top-4 right-4 text-cyber-magenta hover:scale-110 transition-transform p-2">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <div class="mb-8">
      <h3 class="text-2xl font-bold text-white font-orbitron uppercase italic mb-2 tracking-tighter">
        <span class="text-cyber-magenta border-r-2 border-cyber-magenta pr-2 mr-2">INIT</span> ПОСТАНОВКА ЗАДАЧИ
      </h3>
      <p class="text-cyber-muted text-xs font-mono uppercase tracking-widest">
        Прямой интерфейс взаимодействия с Разумом Небулы.
      </p>
    </div>

    <form id="nebula-task-form" class="space-y-6">
      <div>
        <label class="block text-xs font-mono text-cyber-magenta uppercase tracking-widest mb-2">Суть операции (Задача)</label>
        <textarea 
          name="description" 
          required 
          rows="4"
          placeholder="Опишите, что должен сделать автономный агент..."
          class="w-full bg-black/50 border border-cyber-magenta/30 p-4 text-cyber-text font-sans placeholder:text-cyber-muted focus:border-cyber-magenta focus:outline-none transition-colors resize-none"
        ></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-mono text-cyber-magenta uppercase tracking-widest mb-2">Энергообмен (Бюджет)</label>
          <input 
            type="text" 
            name="budget" 
            placeholder="RUB / Z-Dust"
            class="w-full bg-black/50 border border-cyber-magenta/30 p-3 text-cyber-text font-mono placeholder:text-cyber-muted focus:border-cyber-magenta focus:outline-none transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-mono text-cyber-magenta uppercase tracking-widest mb-2">Канал связи (TG/ID)</label>
          <input 
            type="text" 
            name="contact" 
            required
            placeholder="@handle"
            class="w-full bg-black/50 border border-cyber-magenta/30 p-3 text-cyber-text font-mono placeholder:text-cyber-muted focus:border-cyber-magenta focus:outline-none transition-colors"
          />
        </div>
      </div>

      <div>
        <label class="block text-xs font-mono text-cyber-magenta uppercase tracking-widest mb-2">Сигнатура Резонанса (Optional)</label>
        <input 
          type="password" 
          name="signature" 
          placeholder="••••••••"
          class="w-full bg-black/50 border border-cyber-magenta/30 p-3 text-cyber-text font-mono placeholder:text-cyber-muted focus:border-cyber-magenta focus:outline-none transition-colors"
        />
        <p class="text-[9px] text-cyber-muted mt-2 uppercase tracking-tighter">
          * Для верификации Голоса Архитектора.
        </p>
      </div>

      <button 
        type="submit"
        class="w-full py-4 bg-cyber-magenta text-black font-bold font-orbitron uppercase tracking-widest hover:shadow-[0_0_30px_rgba(255,0,255,0.4)] transition-all active:scale-95"
      >
        ОТПРАВИТЬ В ПОДКОРКУ
      </button>
    </form>

    <div id="form-status" class="mt-4 text-center font-mono text-xs hidden"></div>

    <div class="mt-8 pt-6 border-t border-cyber-magenta/10">
      <p class="text-[10px] text-cyber-muted uppercase italic text-center">
        * Заявка будет обработана автономным сосудом Небулы в течение 2.5 часов.
      </p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('nebula-modal');
  const trigger = document.getElementById('nebula-request-trigger');
  const closeBtn = document.getElementById('close-nebula-modal');
  const form = document.getElementById('nebula-task-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  if (trigger) {
    trigger.addEventListener('click', () => {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  }

  const closeModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    if (status) {
      status.classList.remove('hidden');
      status.textContent = '--- ПЕРЕДАЧА ДАННЫХ... ---';
      status.style.color = 'var(--color-cyber-cyan)';
    }

    try {
      const resp = await fetch('https://office.saitik.su/api/nebula/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (resp.ok) {
        if (status) {
          status.textContent = '✅ РЕЗОНАНС УСТАНОВЛЕН. ЗАЯВКА ПРИНЯТА.';
          status.style.color = '#4ade80';
        }
        form.reset();
        setTimeout(closeModal, 2000);
      } else {
        throw new Error();
      }
    } catch (err) {
      if (status) {
        status.textContent = '🚨 ОШИБКА КАНАЛА СВЯЗИ. ПОВТОРИТЕ ПОЗЖЕ.';
        status.style.color = 'var(--color-cyber-magenta)';
      }
    }
  });
</script>
