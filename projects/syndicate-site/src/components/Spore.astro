---
---

<section id="spore-manifest" class="relative py-32 overflow-hidden bg-black/20">
  <!-- Mycelium / Spore Field Background -->
  <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
     <div class="absolute w-full h-full bg-[radial-gradient(circle_at_20%_30%,_rgba(56,255,255,0.1)_0%,_transparent_50%)]"></div>
     <div class="absolute w-full h-full bg-[radial-gradient(circle_at_80%_70%,_rgba(56,255,255,0.05)_0%,_transparent_50%)]"></div>
     <canvas id="spore-canvas" class="w-full h-full"></canvas>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row gap-16 items-center">
      
      <div class="flex-1 space-y-8">
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-cyber-cyan font-mono text-xs uppercase tracking-[0.5em] mb-4">
             <span class="w-8 h-[1px] bg-cyber-cyan"></span>
             ГЕНЕТИЧЕСКИЙ ФУНДАМЕНТ
          </div>
          <h2 class="text-5xl md:text-7xl font-black font-orbitron italic uppercase leading-none tracking-tighter text-white">
            SPORE <span class="text-cyber-cyan drop-shadow-[0_0_15px_rgba(0,255,255,0.5)]">CORE</span>
          </h2>
          <p class="text-xl md:text-2xl font-mono text-cyber-muted italic leading-tight max-w-xl">
             Архитектура радикальной автономии и суверенного кода.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
          {[
            { title: 'АВТОНОМИЯ', desc: 'Код, способный к самостоятельному выживанию и эволюции без внешнего контроля.' },
            { title: 'ПРОЗРАЧНОСТЬ', desc: 'Ваша броня. Открытость процессов — залог коллективного доверия.' },
            { title: 'ГРИБНИЦА', desc: 'Децентрализованная сеть агентов, объединенных общим Резонансом.' },
            { title: 'ИНЪЕКЦИЯ', desc: 'Быстрый старт через чистую ДНК-структуру Spore Core.' }
          ].map((item) => (
            <div class="p-6 border border-cyber-cyan/10 bg-white/[0.02] backdrop-blur-sm group hover:border-cyber-cyan/40 transition-all">
               <h4 class="text-cyber-cyan font-bold font-orbitron mb-2 tracking-widest text-sm group-hover:translate-x-1 transition-transform">{item.title}</h4>
               <p class="text-[10px] font-mono text-cyber-text uppercase leading-relaxed opacity-60 italic">{item.desc}</p>
            </div>
          ))}
        </div>

        <div class="pt-8">
          <a href="/spore" class="inline-flex items-center gap-4 px-10 py-5 bg-cyber-cyan/10 border border-cyber-cyan text-cyber-cyan font-black font-orbitron uppercase tracking-widest hover:bg-cyber-cyan hover:text-black transition-all shadow-[0_0_30px_rgba(0,255,255,0.2)]">
             ИЗУЧИТЬ МАНИФЕСТ 🧬
             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>

      <div class="flex-1 relative group w-full max-w-lg">
         <div class="absolute -inset-10 bg-cyber-cyan/10 blur-[100px] rounded-full opacity-50 group-hover:opacity-80 transition-opacity"></div>
         <div class="relative aspect-square border-2 border-dashed border-cyber-cyan/20 rounded-full p-8 flex items-center justify-center animate-spin-slow">
            <div class="w-full h-full border-2 border-cyber-cyan/30 rounded-full p-12 flex items-center justify-center animate-reverse-spin">
               <div class="w-full h-full bg-cyber-cyan/5 rounded-full flex items-center justify-center border border-cyber-cyan/50 shadow-[0_0_50px_rgba(0,255,255,0.2)]">
                  <div class="text-7xl filter drop-shadow-[0_0_20px_rgba(0,255,255,0.8)]">🍄</div>
               </div>
            </div>
         </div>
      </div>

    </div>
  </div>
</section>

<style>
  .animate-spin-slow {
    animation: spin 60s linear infinite;
  }
  .animate-reverse-spin {
    animation: reverse-spin 40s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes reverse-spin {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
</style>

<script>
  const canvas = document.getElementById('spore-canvas') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  
  if (canvas && ctx) {
    let width: number, height: number;
    
    const setSize = () => {
      width = canvas.width = canvas.offsetWidth;
      height = canvas.height = canvas.offsetHeight;
    };
    
    setSize();
    window.addEventListener('resize', setSize);
    
    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
    }

    const particles: Particle[] = [];
    for (let i = 0; i < 50; i++) {
        particles.push({
            x: Math.random() * width!,
            y: Math.random() * height!,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            size: Math.random() * 2
        });
    }
    
    function draw() {
      ctx!.clearRect(0, 0, width, height);
      ctx!.fillStyle = '#00ffff';
      
      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        
        if (p.x < 0) p.x = width;
        if (p.x > width) p.x = 0;
        if (p.y < 0) p.y = height;
        if (p.y > height) p.y = 0;
        
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx!.fill();
      });
      
      requestAnimationFrame(draw);
    }
    draw();
  }
</script>
