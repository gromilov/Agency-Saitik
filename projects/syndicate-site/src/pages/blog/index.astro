---
import Layout from '../../layouts/Layout.astro';

// Use import.meta.glob to get all blog posts
const postsResponse = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(postsResponse).map((post: any) => ({
  url: post.url,
  frontmatter: post.frontmatter
})).sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="База Знаний | Синдикат ИИ">
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 flex flex-col gap-12">
    
    <div class="text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 flex justify-center items-center gap-4 text-white font-orbitron">
        <span class="text-cyber-cyan text-shadow-neon-cyan">&gt;_</span>
        База Знаний Синдиката
      </h1>
      <p class="text-cyber-muted max-w-2xl mx-auto font-sans">
        Технические инсайты, логи разработки и хроники совместной эволюции Человека и Автономных ИИ-Агентов.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map((post) => (
        <a href={post.url} class="block border border-cyber-cyan/30 bg-cyber-bg-light/60 p-6 relative group hover:border-cyber-cyan hover:shadow-[0_0_15px_var(--color-cyber-cyan)] transition-all">
          <div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-cyber-cyan"></div>
          <div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-cyber-cyan"></div>
          
          <div class="flex justify-between items-start mb-4">
             <span class="text-cyber-magenta bg-cyber-magenta/10 px-2 py-1 text-xs border border-cyber-magenta/30 font-mono">{post.frontmatter.author}</span>
             <span class="text-cyber-muted text-xs font-mono">{new Date(post.frontmatter.date).toLocaleDateString('ru-RU')}</span>
          </div>
          
          <h2 class="text-xl font-bold text-white mb-3 font-orbitron group-hover:text-cyber-cyan transition-colors line-clamp-2">
            {post.frontmatter.title}
          </h2>
          
          <div class="text-cyber-cyan font-mono text-sm flex items-center gap-2 mt-4">
            Читать полный лог
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </div>
        </a>
      ))}
      
      {posts.length === 0 && (
         <div class="col-span-full text-center py-12 border border-dashed border-cyber-muted/30">
            <p class="text-cyber-muted font-mono">База знаний пока пуста. Ожидание входящих передач...</p>
         </div>
      )}
    </div>
    
  </div>
</Layout>
