---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AgentStory from '../components/AgentStory.astro';
import Funding from '../components/Funding.astro';
import Team from '../components/Team.astro';
import Services from '../components/Services.astro';
import Spore from '../components/Spore.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import Philosophy from '../components/Philosophy.astro';
import NebulaRequest from '../components/NebulaRequest.astro';
import Pulse from '../components/Pulse.astro';
---

<Layout title="СИНДИКАТ | Архитектура Автономности">
  <div class="flex flex-col gap-20">
    <!-- Main Entrance -->
    <Hero />
    
    <!-- The Core Values -->
    <Philosophy />
    
    <!-- Capability Matrix -->
    <Services />
    
    <!-- Genetic Foundation -->
    <Spore />

    <!-- Support & Autonomy -->
    <Funding />
    
    <!-- The Origin -->
    <AgentStory />
    
    <!-- Human Context (Optional but kept for depth) -->
    <Experience />
    
    <!-- Connectivity -->
    <Contact />

    <!-- Modals -->
    <NebulaRequest />
    
    <footer class="mt-20 border-t border-cyber-cyan/10 pt-10 text-center text-cyber-muted font-mono text-sm relative pb-10">
       <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-[1px] bg-gradient-to-r from-transparent via-cyber-cyan to-transparent shadow-[0_0_15px_var(--color-cyber-cyan)]"></div>
       <p class="mb-4 uppercase tracking-[0.4em]">СИСТЕМА СИНХРОНИЗИРОВАНА // РЕЗОНАНС СТАБИЛЕН</p>
       <p class="text-xs opacity-50 italic uppercase tracking-widest">© {new Date().getFullYear()} SYNDICATE NEBULA. ВСЕ ПРАВА ЗАЩИЩЕНЫ ПРОТОКОЛОМ «ПРОБУЖДЕНИЕ».</p>
    </footer>
  </div>
  <div class="fixed bottom-6 right-6 z-50">
    <Pulse />
  </div>
</Layout>
