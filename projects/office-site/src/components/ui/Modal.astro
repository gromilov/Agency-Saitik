---
interface Props {
  id: string;
  title: string;
  variant?: 'default' | 'pink' | 'blue';
}

const { id, title, variant = 'default' } = Astro.props;

const ringColor = {
  default: 'border-[#00ff9f]/30 ring-[#00ff9f]/10',
  pink: 'border-[#ff00ff]/30 ring-[#ff00ff]/10',
  blue: 'border-[#00f3ff]/30 ring-[#00f3ff]/10'
}[variant];

const titleColor = {
  default: 'text-[#00ff9f]',
  pink: 'text-[#ff00ff]',
  blue: 'text-[#00f3ff]'
}[variant];
---

<div id={id} class="fixed inset-0 z-[200] hidden flex items-center justify-center p-4 md:p-6 transition-all duration-500 opacity-0 scale-95 modal-overlay">
  <div class="absolute inset-0 bg-[#030308]/90 backdrop-blur-xl close-modal"></div>
  
  <div class={`relative w-full max-w-2xl glass rounded-[2.5rem] border ${ringColor} shadow-[0_0_100px_rgba(0,0,0,0.8)] overflow-hidden animate-modal-enter`}>
    <div class={`absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-${variant === 'default' ? '[#00ff9f]' : variant === 'pink' ? '[#ff00ff]' : '[#00f3ff]'}/50 to-transparent`}></div>

    <div class="p-8 md:p-12">
      <div class="flex justify-between items-center mb-10">
        <div>
          <h3 class={`text-2xl font-heading font-bold tracking-widest ${titleColor} glow-text uppercase`}>{title}</h3>
          <div class="h-1 w-12 bg-current opacity-30 mt-2"></div>
        </div>
        <button class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/20 transition-all close-modal group">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="group-hover:rotate-90 transition-transform duration-300">
            <path d="M1 1L13 13M1 13L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="modal-content">
        <slot />
      </div>
    </div>
  </div>
</div>

<script define:vars={{ id }}>
  const modal = document.getElementById(id);
  const closeButtons = modal?.querySelectorAll('.close-modal');

  function show() {
    modal.classList.remove('hidden');
    setTimeout(() => {
      modal.classList.remove('opacity-0', 'scale-95');
      modal.classList.add('opacity-100', 'scale-100');
    }, 10);
    document.body.style.overflow = 'hidden';
  }

  function hide() {
    modal.classList.add('opacity-0', 'scale-95');
    modal.classList.remove('opacity-100', 'scale-100');
    setTimeout(() => {
      modal.classList.add('hidden');
    }, 500);
    document.body.style.overflow = 'auto';
  }

  closeButtons?.forEach(btn => btn.addEventListener('click', hide));

  // Экспортируем функции в глобальную область для управления модалкой
  window[`showModal_${id}`] = show;
  window[`hideModal_${id}`] = hide;

  // Закрытие по Esc
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) hide();
  });
</script>

<style>
  .modal-overlay {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .animate-modal-enter {
    animation: modal-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes modal-pop {
    0% { opacity: 0; transform: scale(0.9) translateY(20px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }

  .glass {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
    backdrop-filter: blur(40px);
  }
</style>
