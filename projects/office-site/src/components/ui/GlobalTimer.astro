---
import { db } from '../../db';
import { projects } from '../../db/schema';

const allProjects = await db.select().from(projects);
---

<div id="cyber-timer" class="fixed bottom-8 right-8 z-[100] transition-all duration-700 translate-y-20 opacity-0 group/timer">
  <!-- Переключатель свернутого состояния -->
  <button id="timer-toggle" class="absolute -top-3 -left-3 w-8 h-8 rounded-full bg-[#030308] border border-white/10 flex items-center justify-center text-white/40 hover:text-[#00ff9f] hover:border-[#00ff9f]/40 transition-all z-20 shadow-xl opacity-0 group-hover/timer:opacity-100">
    <svg id="toggle-icon" width="10" height="10" viewBox="0 0 10 10" fill="none" class="transition-transform duration-500">
      <path d="M1 1L9 9M1 9L9 1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <div id="timer-container" class="glass relative p-1 rounded-2xl border border-white/10 shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden transition-all duration-500 w-16 h-16 origin-bottom-right cursor-pointer hover:scale-105 active:scale-95">
    <!-- Гламурный фон индикатора -->
    <div id="timer-pulse" class="absolute inset-0 bg-[#00ff9f]/5 opacity-0 transition-opacity duration-1000"></div>
    
    <!-- Свернутый вид (Иконка/Индикатор) -->
    <div id="timer-collapsed" class="absolute inset-0 flex items-center justify-center">
        <div id="indicator-minimal" class="w-2.5 h-2.5 rounded-full bg-white/10 transition-all duration-500"></div>
        <div class="absolute inset-0 border-2 border-white/5 rounded-2xl animate-[spin_10s_linear_infinite]"></div>
    </div>

    <!-- Развернутый вид -->
    <div id="timer-expanded" class="hidden relative p-4 md:p-6 md:px-8 flex flex-col md:flex-row items-center gap-4 md:gap-8 bg-black/40 rounded-xl opacity-0 transition-opacity duration-500">
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <span id="timer-label" class="text-[9px] uppercase tracking-[0.3em] font-black text-white/30 mb-1">ПОТОК::ОЖИДАНИЕ</span>
        <div class="flex items-baseline gap-2">
          <span id="timer-display" class="text-3xl font-mono font-bold text-white tracking-tighter">00:00:00</span>
          <div id="active-indicator" class="w-2 h-2 rounded-full bg-white/10"></div>
        </div>
      </div>

      <div class="flex gap-4 items-center">
        <!-- Селектор проекта -->
        <select id="timer-project-select" class="bg-white/5 border border-white/10 text-[10px] uppercase font-bold tracking-widest p-2 px-4 rounded-lg outline-none focus:border-[#00ff9f]/40 text-white/60 max-w-[150px] truncate">
          <option value="">ВЫБРАТЬ_ЦЕЛЬ</option>
          {allProjects.map(p => (
            <option value={p.id}>{p.name}</option>
          ))}
        </select>

        <!-- Кнопки управления -->
        <button id="timer-start-btn" class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-[#00ff9f]/10 border border-[#00ff9f]/20 flex items-center justify-center text-[#00ff9f] hover:bg-[#00ff9f] hover:text-black transition-all group/btn shadow-[0_0_20px_rgba(0,255,159,0.1)]">
          <svg width="12" height="14" viewBox="0 0 12 14" fill="none" class="ml-1"><path d="M1 1L11 7L1 13V1Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </button>

        <button id="timer-stop-btn" class="hidden w-10 h-10 md:w-12 md:h-12 rounded-xl bg-[#ff00ff]/10 border border-[#ff00ff]/20 flex items-center justify-center text-[#ff00ff] hover:bg-[#ff00ff] hover:text-white transition-all group/btn shadow-[0_0_20px_rgba(255,0,255,0.1)]">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="1" width="10" height="10" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Модалка описания -->
<div id="timer-modal" class="fixed inset-0 z-[110] hidden flex items-center justify-center p-6 bg-black/80 backdrop-blur-md">
    <div class="glass relative max-w-md w-full p-10 rounded-[2.5rem] border border-white/5 shadow-2xl">
        <h3 class="text-2xl font-heading text-white mb-6 uppercase tracking-widest">ФИКСАЦИЯ_КВАНТА</h3>
        <p class="text-[10px] text-white/40 mb-8 uppercase tracking-widest font-bold">Опишите выполненную работу для завершения цикла:</p>
        
        <textarea id="timer-description" placeholder="МАНИФЕСТ_ЗАДАЧИ..." class="w-full h-32 bg-black/40 border border-white/10 p-4 rounded-2xl focus:border-[#00ff9f] outline-none text-white font-mono text-sm mb-8 resize-none shadow-inner"></textarea>
        
        <div class="flex gap-4">
            <button id="timer-cancel-stop" class="flex-1 p-4 rounded-xl border border-white/5 text-[10px] uppercase font-bold tracking-widest text-white/40 hover:text-white transition-all">Отмена</button>
            <button id="timer-confirm-stop" class="flex-[2] p-4 rounded-xl bg-[#00ff9f] text-black text-[10px] uppercase font-bold tracking-widest hover:shadow-[0_0_30px_#00ff9f] transition-all">Зафиксировать</button>
        </div>
    </div>
</div>

<script>
  let seconds = 0;
  let timerInterval: any = null;
  let activeProjectId: string | null = null;
  let isExpanded = false;

  const display = document.getElementById('timer-display');
  const label = document.getElementById('timer-label');
  const widget = document.getElementById('cyber-timer');
  const container = document.getElementById('timer-container');
  const collapsedView = document.getElementById('timer-collapsed');
  const expandedView = document.getElementById('timer-expanded');
  const indicatorMin = document.getElementById('indicator-minimal');
  const toggleBtn = document.getElementById('timer-toggle');
  const toggleIcon = document.getElementById('toggle-icon');

  const startBtn = document.getElementById('timer-start-btn');
  const stopBtn = document.getElementById('timer-stop-btn');
  const select = document.getElementById('timer-project-select') as HTMLSelectElement;
  const indicator = document.getElementById('active-indicator');
  const pulse = document.getElementById('timer-pulse');
  
  const modal = document.getElementById('timer-modal');
  const confirmStop = document.getElementById('timer-confirm-stop');
  const cancelStop = document.getElementById('timer-cancel-stop');
  const descriptionInput = document.getElementById('timer-description') as HTMLTextAreaElement;

  function toggleTimer(force?: boolean) {
    isExpanded = force !== undefined ? force : !isExpanded;
    
    if (isExpanded) {
      container!.style.width = window.innerWidth < 768 ? 'calc(100vw - 4rem)' : 'auto';
      container!.style.height = 'auto';
      container!.style.maxWidth = '500px';
      container!.classList.remove('cursor-pointer');
      collapsedView!.classList.add('opacity-0', 'scale-50');
      expandedView!.classList.remove('hidden');
      setTimeout(() => {
        expandedView!.classList.remove('opacity-0');
        collapsedView!.classList.add('hidden');
      }, 300);
      toggleIcon!.style.transform = 'rotate(0deg)';
      toggleBtn!.classList.remove('hidden');
    } else {
      expandedView!.classList.add('opacity-0');
      setTimeout(() => {
        expandedView!.classList.add('hidden');
        collapsedView!.classList.remove('hidden');
        collapsedView!.classList.remove('opacity-0', 'scale-50');
        container!.style.width = '64px';
        container!.style.height = '64px';
        container!.classList.add('cursor-pointer');
      }, 300);
      toggleIcon!.style.transform = 'rotate(45deg)';
    }
  }

  container?.addEventListener('click', () => {
    if (!isExpanded) toggleTimer(true);
  });

  toggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleTimer(false);
  });

  function updateDisplay() {
    const h = Math.floor(seconds / 3600).toString().padStart(2, '0');
    const m = Math.floor((seconds % 3600) / 60).toString().padStart(2, '0');
    const s = Math.floor(seconds % 60).toString().padStart(2, '0');
    if (display) display.textContent = `${h}:${m}:${s}`;
  }

  function setVisualState(active: boolean) {
    if (active) {
      label!.textContent = 'ПОТОК::АКТИВЕН';
      label!.classList.add('text-[#00ff9f]');
      label!.classList.remove('text-white/30');
      indicator!.classList.add('bg-[#00ff9f]', 'animate-ping', 'shadow-[0_0_10px_#00ff9f]');
      indicatorMin!.classList.add('bg-[#00ff9f]', 'animate-ping', 'shadow-[0_0_10px_#00ff9f]');
      pulse!.classList.add('opacity-100');
      startBtn!.classList.add('hidden');
      stopBtn!.classList.remove('hidden');
      select!.classList.add('hidden');
    } else {
      label!.textContent = 'ПОТОК::ОЖИДАНИЕ';
      label!.classList.remove('text-[#00ff9f]');
      label!.classList.add('text-white/30');
      indicator!.classList.remove('bg-[#00ff9f]', 'animate-ping', 'shadow-[0_0_10px_#00ff9f]');
      indicatorMin!.classList.remove('bg-[#00ff9f]', 'animate-ping', 'shadow-[0_0_10px_#00ff9f]');
      indicatorMin!.classList.add('bg-white/10');
      pulse!.classList.remove('opacity-100');
      startBtn!.classList.remove('hidden');
      stopBtn!.classList.add('hidden');
      select!.classList.remove('hidden');
    }
  }

  async function checkStatus() {
    try {
      const res = await fetch('/api/timer/status');
      const data = await res.json();
      
      if (data.active) {
        seconds = data.elapsedSeconds;
        activeProjectId = data.projectId;
        setVisualState(true);
        startLocalTimer();
        // Если таймер активен, можно развернуть его сразу
        // toggleTimer(true); 
      } else {
        setVisualState(false);
      }
      
      widget!.classList.remove('translate-y-20', 'opacity-0');
    } catch (e) {
      console.error('Timer Status Check Failed', e);
    }
  }

  function startLocalTimer() {
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      seconds++;
      updateDisplay();
    }, 1000);
  }

  startBtn?.addEventListener('click', async () => {
    const projectId = select!.value;
    if (!projectId) return alert('ВЫБЕРИТЕ_ЦЕЛЬ');

    const res = await fetch('/api/timer/start', {
      method: 'POST',
      body: JSON.stringify({ projectId }),
      headers: { 'Content-Type': 'application/json' }
    });

    if (res.ok) {
      seconds = 0;
      activeProjectId = projectId;
      setVisualState(true);
      startLocalTimer();
      updateDisplay();
    }
  });

  stopBtn?.addEventListener('click', () => {
    modal!.classList.remove('hidden');
  });

  cancelStop?.addEventListener('click', () => {
      modal!.classList.add('hidden');
  });

  confirmStop?.addEventListener('click', async () => {
    const description = descriptionInput.value;
    if (!description) return alert('ОПИШИТЕ_РАБОТУ');

    const res = await fetch('/api/timer/stop', {
      method: 'POST',
      body: JSON.stringify({ description }),
      headers: { 'Content-Type': 'application/json' }
    });

    if (res.ok) {
        const data = await res.json();
        alert(`ЗАТРАТЫ_ЗАРЕГИСТРИРОВАНЫ: ${data.minutes} МИН`);
        
        clearInterval(timerInterval);
        seconds = 0;
        activeProjectId = null;
        descriptionInput.value = '';
        modal!.classList.add('hidden');
        setVisualState(false);
        updateDisplay();
        toggleTimer(false);
    }
  });

  // Инициализация
  checkStatus();
</script>
