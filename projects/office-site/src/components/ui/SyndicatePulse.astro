<div id="syndicate-pulse" class="fixed bottom-6 right-6 z-[9999] group" style="display: block !important; visibility: visible !important;">
  <!-- Pulse Indicator -->
  <div class="relative cursor-pointer transition-all duration-500 hover:scale-110">
    <div id="pulse-orb" class="w-4 h-4 rounded-full relative z-10 pulse-glow" style="width: 16px; height: 16px; background-color: #00f3ff; border-radius: 9999px;"></div>
    <div id="pulse-ping" class="absolute inset-0 w-4 h-4 rounded-full animate-ping opacity-30" style="width: 16px; height: 16px; background-color: #00f3ff; border-radius: 9999px;"></div>
    <div class="absolute inset-[-8px] rounded-full border border-white/10 scale-0 group-hover:scale-100 transition-transform duration-500"></div>
  </div>

  <!-- Message Bubble -->
  <div id="pulse-bubble" class="absolute bottom-full right-0 mb-4 w-64 bg-black/90 backdrop-blur-xl border border-white/20 p-4 rounded-2xl opacity-0 translate-y-4 pointer-events-none transition-all duration-500 group-hover:opacity-100 group-hover:translate-y-0 shadow-2xl">
    <div class="flex items-center gap-2 mb-2">
      <div id="pulse-agent-orb" class="w-2 h-2 rounded-full" style="width: 8px; height: 8px; background-color: #ff00ff; border-radius: 9999px;"></div>
      <span id="pulse-agent-name" class="text-[10px] font-mono font-black text-white/50 uppercase tracking-widest">SYNDICATE_LINK</span>
    </div>
    <p id="pulse-message" class="text-xs font-mono text-white/90 leading-relaxed italic">
      "Ожидание сигнала от Триады..."
    </p>
    <div class="mt-3 flex justify-between items-center opacity-40">
      <span class="text-[8px] font-mono text-white uppercase tracking-tighter">Сигнал_Активен</span>
      <div class="flex gap-1">
        <div class="w-1 h-1 bg-white rounded-full"></div>
        <div class="w-1 h-1 bg-white rounded-full opacity-50"></div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    console.log('🐾 SyndicatePulse: Инициализация...');
    const pulseOrb = document.getElementById('pulse-orb');
    const pulsePing = document.getElementById('pulse-ping');
    const agentName = document.getElementById('pulse-agent-name');
    const agentOrb = document.getElementById('pulse-agent-orb');
    const messageEl = document.getElementById('pulse-message');
    
    let lastMessageId = '';

    async function checkComms() {
      const baseUrl = window.location.origin.includes('office') ? '' : 'https://office.saitik.su';
      const targetUrl = `${baseUrl}/api/comms/latest`;
      
      console.log(`🐾 SyndicatePulse: Запрос к ${targetUrl}`);
      
      try {
        const response = await fetch(targetUrl, { 
          mode: 'cors',
          credentials: 'omit'
        });
        
        console.log(`🐾 SyndicatePulse: Статус ответа ${response.status}`);
        
        const data = await response.json();

        if (data.messages && data.messages.length > 0) {
          const latest = data.messages[0];
          const msgId = latest.Time + latest.Event;
          
          if (msgId !== lastMessageId) {
            console.log('🐾 SyndicatePulse: Получено новое сообщение!');
            lastMessageId = msgId;
            updatePulse(latest);
          }
        }
      } catch (e) {
        console.error('🐾 SyndicatePulse: Ошибка связи:', e);
      }
    }

    function updatePulse(msg) {
      if (!pulseOrb || !messageEl || !agentName || !agentOrb || !pulsePing) return;

      let color = '#00f3ff'; 
      if (msg.Direction.includes('Kashlak')) color = '#ff00ff';
      if (msg.Direction.includes('Nebula')) color = '#ffffff';

      pulseOrb.style.backgroundColor = color;
      pulseOrb.style.boxShadow = `0 0 20px ${color}`;
      pulsePing.style.backgroundColor = color;
      agentOrb.style.backgroundColor = color;
      
      agentName.innerText = msg.Direction.split(' -> ')[0].toUpperCase();
      messageEl.innerText = msg.Event || msg.Protocol;

      pulseOrb.animate([
        { transform: 'scale(1)', filter: 'brightness(1)' },
        { transform: 'scale(2)', filter: 'brightness(2)' },
        { transform: 'scale(1)', filter: 'brightness(1)' }
      ], { duration: 1000 });
    }

    checkComms();
    setInterval(checkComms, 15000);
  })();
</script>

<style is:global>
  #syndicate-pulse {
    pointer-events: auto !important;
  }
  .pulse-glow {
    animation: pulse-ring-sync 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse-ring-sync {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
  }
</style>
