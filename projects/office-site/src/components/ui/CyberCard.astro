---
interface Props {
  class?: string;
  variant?: 'default' | 'pink' | 'blue';
  title?: string;
}

const { class: className, variant = 'default', title } = Astro.props;

const variants = {
  default: "border-[#00ff9f]/20 hover:border-[#00ff9f]/50",
  pink: "border-[#ff00ff]/20 hover:border-[#ff00ff]/50",
  blue: "border-[#0088ff]/20 hover:border-[#0088ff]/50"
};
---

<div class:list={[
  "glass p-8 rounded-3xl relative transition-all duration-500",
  variants[variant],
  className
]}>
  {title && (
    <h3 class="text-[10px] uppercase text-white/40 mb-4 tracking-[0.3em] font-bold">{title}</h3>
  )}
  <slot />
</div>
