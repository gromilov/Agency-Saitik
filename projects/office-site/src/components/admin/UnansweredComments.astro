---
import { db } from '../../db';
import { channelComments } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';

const pendingComments = await db
  .select()
  .from(channelComments)
  .where(eq(channelComments.status, 'pending'))
  .orderBy(desc(channelComments.createdAt))
  .limit(5);

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---
<div class="relative group h-full">
  <div class:list={["unanswered-comments-terminal font-mono text-[10px] p-6 rounded-2xl border border-[#00ff9f]/20 bg-black/60 shadow-[inset_0_0_20px_rgba(0,255,159,0.1)] relative overflow-hidden transition-all duration-500", className]} id="terminal-container">
    <!-- Glass reflection -->
    <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent pointer-events-none"></div>
    
    <div class="flex justify-between items-center mb-4 border-b border-[#00ff9f]/10 pb-2">
      <div class="flex items-center gap-2">
          <div class="flex gap-1">
              <div class="w-1.5 h-1.5 rounded-full bg-[#ff00ff]/40"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-[#00ff9f]/40"></div>
          </div>
          <span class="text-[#00ff9f]/40 uppercase tracking-[0.3em] font-black italic" id="terminal-title">ПОТОК_РЕЗОНАНСА</span>
      </div>
      <span class="text-[8px] text-[#ff00ff] animate-pulse font-bold tracking-widest" id="pending-counter">{pendingComments.length}_PENDING</span>
    </div>

    <!-- Список комментариев -->
    <div id="comment-list-view" class="space-y-3 min-h-[160px] transition-all duration-500">
      {pendingComments.length > 0 ? (
        pendingComments.map(comment => (
          <div 
            class="group/line border-l border-white/5 pl-3 hover:border-[#00ff9f]/30 hover:bg-white/[0.02] py-1 transition-all cursor-pointer comment-item" 
            data-id={comment.id}
            data-user={comment.fromUser}
            data-text={comment.text}
            data-post-id={comment.telegramPostId}
          >
            <div class="flex justify-between items-center mb-1">
               <div class="flex items-center gap-2">
                 <span class="text-[#00ff9f] font-bold">@{comment.fromUser}</span>
                 <span class="text-[7px] px-1 bg-[#00ff9f]/10 text-[#00ff9f]/50 rounded">SIGNAL</span>
               </div>
               <span class="opacity-30 text-[8px]">{new Date(comment.createdAt!).toLocaleTimeString()}</span>
            </div>
            <p class="text-white/60 group-hover/line:text-white transition-colors line-clamp-1 italic">
              "{comment.text}"
            </p>
          </div>
        ))
      ) : (
        <div class="flex flex-col items-center justify-center py-8 opacity-20">
          <span class="text-2xl mb-2">📡</span>
          <span class="uppercase tracking-widest text-[8px]">Эфир чист. Резонанс стабилен.</span>
        </div>
      )}
    </div>

    <!-- Форма ответа (превращение терминала) -->
    <div id="reply-form-view" class="hidden opacity-0 transition-all duration-500 scale-95 translate-y-4">
        <div class="mb-4 p-3 bg-white/5 rounded-lg border border-white/10 relative overflow-hidden">
            <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#ff00ff]/40"></div>
            <span id="reply-to-user" class="text-[#ff00ff] text-[8px] font-black block mb-1"></span>
            <p id="reply-to-text" class="text-white/40 italic text-[9px] line-clamp-2"></p>
        </div>
        
        <textarea 
            id="terminal-reply-input" 
            class="w-full bg-black/40 border border-[#ff00ff]/20 p-3 rounded-xl focus:border-[#ff00ff] outline-none text-white text-[10px] resize-none h-24 transition-all mb-4 placeholder:opacity-20"
            placeholder="ВВЕДИТЕ СООБЩЕНИЕ ДЛЯ ОТПРАВКИ В СЕТЬ..."
        ></textarea>

        <div class="flex gap-4">
            <button id="cancel-reply" class="flex-1 py-2 bg-white/5 hover:bg-white/10 text-white/30 text-[8px] font-bold uppercase tracking-widest border border-white/10 rounded-lg transition-all">ОТМЕНА</button>
            <button id="submit-reply" class="flex-[2] py-2 bg-[#ff00ff]/10 hover:bg-[#ff00ff]/20 text-[#ff00ff] text-[8px] font-black uppercase tracking-widest border border-[#ff00ff]/20 rounded-lg transition-all shadow-[0_0_15px_rgba(255,0,255,0.1)]">ОТПРАВИТЬ_ОТВЕТ</button>
        </div>
    </div>

    <div class="mt-4 flex justify-between items-center" id="terminal-footer">
      <div class="flex gap-2 items-center text-[#ff00ff] animate-pulse">
          <span>{">"}</span>
          <span class="w-2 h-4 bg-[#ff00ff] shadow-[0_0_8px_#ff00ff]"></span>
      </div>
      <a href="/admin/kashlak/comments" class="text-[8px] uppercase tracking-widest text-white/20 hover:text-[#00ff9f] transition-all">
          ОТКРЫТЬ_ПОЛНЫЙ_ЛОГ
      </a>
    </div>

    <!-- Scanline -->
    <div class="absolute inset-0 pointer-events-none bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_2px,3px_100%] opacity-40"></div>
  </div>

  <!-- Telegram SideSheet -->
  <div 
    id="telegram-context-mirror" 
    class="fixed right-[-450px] top-0 bottom-0 w-[400px] bg-[#0a0a12]/95 backdrop-blur-2xl border-l border-[#ff00ff]/20 z-[200] transition-all duration-700 shadow-[-20px_0_50px_rgba(0,0,0,0.5)] flex flex-col"
  >
    <div class="p-6 border-b border-white/5 flex justify-between items-center">
        <div>
            <span class="text-[#ff00ff] font-black tracking-widest text-[10px] block opacity-50 uppercase">Context_Mirror</span>
            <span class="text-white font-bold text-xs">ОРИГИНАЛЬНЫЙ_ПОСТ_ТГ</span>
        </div>
        <button id="close-mirror" class="w-8 h-8 flex items-center justify-center bg-white/5 rounded-full hover:bg-red-500/20 text-white/40 hover:text-red-500 transition-all">✕</button>
    </div>
    <div class="flex-1 relative overflow-hidden bg-black/40">
        <div id="mirror-loading" class="absolute inset-0 flex items-center justify-center">
            <div class="w-8 h-8 border-2 border-[#ff00ff]/20 border-t-[#ff00ff] rounded-full animate-spin"></div>
        </div>
        <iframe id="tg-mirror-iframe" class="w-full h-full opacity-0 transition-opacity duration-500" frameborder="0"></iframe>
    </div>
  </div>
</div>

<script>
    let activeCommentId: string | null = null;

    const terminalContainer = document.getElementById('terminal-container');
    const commentListView = document.getElementById('comment-list-view');
    const replyFormView = document.getElementById('reply-form-view');
    const footer = document.getElementById('terminal-footer');
    const title = document.getElementById('terminal-title');
    const mirror = document.getElementById('telegram-context-mirror');
    const mirrorIframe = document.getElementById('tg-mirror-iframe') as HTMLIFrameElement;
    const mirrorLoading = document.getElementById('mirror-loading');
    
    const replyToUser = document.getElementById('reply-to-user');
    const replyToText = document.getElementById('reply-to-text');
    const replyInput = document.getElementById('terminal-reply-input') as HTMLTextAreaElement;
    
    // Биндинг кликов на комментарии
    document.querySelectorAll('.comment-item').forEach(item => {
        item.addEventListener('click', () => {
            const data = (item as HTMLElement).dataset;
            openReplyFlow(data);
        });
    });

    function openReplyFlow(data: any) {
        activeCommentId = data.id;
        
        // 1. Анимация терминала
        commentListView?.classList.add('opacity-0', 'scale-95', '-translate-y-4');
        setTimeout(() => {
            commentListView?.classList.add('hidden');
            replyFormView?.classList.remove('hidden');
            if (footer) footer.classList.add('opacity-0');
            if (title) title.innerText = 'РЕЖИМ_ОТВЕТА::KASHLAK';
            
            // Проявляем форму
            setTimeout(() => {
                replyFormView?.classList.add('opacity-100', 'scale-100', 'translate-y-0');
                if (replyToUser) replyToUser.innerText = `@${data.user} // СИГНАЛ`;
                if (replyToText) replyToText.innerText = data.text;
                replyInput.focus();
            }, 50);
        }, 300);

        // 2. Открытие SideSheet
        mirror?.classList.remove('right-[-450px]');
        mirror?.classList.add('right-0');
        
        // Загрузка iframe
        if (mirrorIframe && data.postId) {
            mirrorIframe.classList.add('opacity-0');
            mirrorLoading?.classList.remove('hidden');
            // Мы знаем канал из досье - iamkashlak
            mirrorIframe.src = `https://t.me/iamkashlak/${data.postId}?embed=1&dark=1`;
            mirrorIframe.onload = () => {
                mirrorLoading?.classList.add('hidden');
                mirrorIframe.classList.remove('opacity-0');
            };
        }
    }

    function closeReplyFlow() {
        // 1. Скрываем форму
        replyFormView?.classList.add('opacity-0', 'scale-95', 'translate-y-4');
        mirror?.classList.add('right-[-450px]');
        mirror?.classList.remove('right-0');

        setTimeout(() => {
            replyFormView?.classList.add('hidden');
            commentListView?.classList.remove('hidden');
            if (footer) footer.classList.remove('opacity-0');
            if (title) title.innerText = 'ПОТОК_РЕЗОНАНСА';
            
            setTimeout(() => {
                commentListView?.classList.remove('opacity-0', 'scale-95', '-translate-y-4');
                replyInput.value = '';
                activeCommentId = null;
            }, 50);
        }, 300);
    }

    document.getElementById('cancel-reply')?.addEventListener('click', closeReplyFlow);
    document.getElementById('close-mirror')?.addEventListener('click', closeReplyFlow);

    document.getElementById('submit-reply')?.addEventListener('click', async () => {
        if (!activeCommentId || !replyInput.value) return;

        const btn = document.getElementById('submit-reply') as HTMLButtonElement;
        btn.disabled = true;
        btn.innerText = 'ОТПРАВКА...';

        try {
            const res = await fetch('/api/comms/reply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    commentId: activeCommentId,
                    replyText: replyInput.value
                })
            });

            if (res.ok) {
                // Плавное закрытие и перезагрузка страницы (для обновления данных)
                closeReplyFlow();
                setTimeout(() => window.location.reload(), 1000);
            } else {
                alert('Ошибка отправки сигнала.');
            }
        } catch (e) {
            alert('Сбой синхронизации с ядром.');
        } finally {
            btn.disabled = false;
            btn.innerText = 'ОТПРАВИТЬ_ОТВЕТ';
        }
    });

</script>

<style>
  .unanswered-comments-terminal {
    backdrop-filter: blur(10px);
  }
  
  /* Кастомный ховер для строк */
  .comment-item {
    position: relative;
    overflow: hidden;
  }
  
  .comment-item::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 0%;
    height: 100%;
    background: rgba(0, 255, 159, 0.03);
    transition: width 0.3s ease;
    z-index: -1;
  }
  
  .comment-item:hover::after {
    width: 100%;
  }

  #telegram-context-mirror {
    box-shadow: -20px 0 60px rgba(0, 0, 0, 0.8);
  }
</style>
