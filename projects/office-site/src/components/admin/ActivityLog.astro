---
interface Props {
  sessions: Array<{
    id: string;
    date: string;
    description: string;
    minutes: number;
  }>;
}

const { sessions } = Astro.props;
---

<section class="glass rounded-3xl overflow-hidden border border-white/5 bg-[#030308]/40 shadow-2xl relative group">
  <!-- Scan line effect -->
  <div class="absolute inset-x-0 top-0 h-[1px] bg-[#ff00ff]/20 shadow-[0_0_10px_#ff00ff] animate-[scan_4s_linear_infinite] opacity-0 group-hover:opacity-100 pointer-events-none"></div>

  <div class="p-8 border-b border-white/5 bg-white/[0.02] flex justify-between items-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-[#ff00ff]/5 to-transparent skew-x-12 -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
    <h2 class="text-xl font-heading flex items-center gap-3 text-white leading-none relative">
      <span class="text-[#ff00ff] italic group-hover:animate-pulse">{" > "}</span> ЖУРНАЛ_ЭНЕРГИИ
    </h2>
    <div class="flex items-center gap-3 opacity-60">
      <span class="text-[9px] text-[#00ff9f] font-mono tracking-tighter uppercase animate-pulse">Трансляция...</span>
      <div class="w-1.5 h-1.5 rounded-full bg-[#00ff9f]"></div>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left text-xs font-mono">
      <thead>
        <tr class="bg-white/[0.03] text-white/40 uppercase tracking-[0.2em] font-bold border-b border-white/5">
          <th class="p-6">МЕТКА_ВРЕМЕНИ</th>
          <th class="p-6">МАНИФЕСТ_ЗАДАЧИ</th>
          <th class="p-6 text-right">КВАНТ_МИН</th>
          <th class="p-6 text-right w-10">ДЕЙСТВИЕ</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/5">
        {sessions.length === 0 ? (
          <tr>
            <td colspan="4" class="p-24 text-center">
              <div class="flex flex-col items-center gap-6 opacity-20 group-hover:opacity-40 transition-opacity">
                <div class="text-7xl font-mono">∅</div>
                <p class="text-[10px] uppercase tracking-[0.5em] font-black">Буфер нейросети пуст. Ожидание активности...</p>
              </div>
            </td>
          </tr>
        ) : (
          sessions.map(s => (
            <tr class="hover:bg-[#ff00ff]/5 transition-all duration-300 group/row" id={`session-${s.id}`}>
              <td class="p-6 opacity-40 group-hover/row:opacity-100 transition-opacity font-bold text-[10px] tracking-widest">{s.date}</td>
              <td class="p-6 text-white/70 group-hover/row:text-white transition-colors relative">
                <div class="flex items-center gap-2">
                   <span class="w-1 h-3 bg-[#ff00ff]/20 group-hover/row:bg-[#ff00ff]/60 transition-colors"></span>
                   {s.description}
                </div>
              </td>
              <td class="p-6 text-right">
                <span class="bg-[#ff00ff]/10 text-[#ff00ff] border border-[#ff00ff]/20 px-4 py-1.5 rounded-lg font-black shadow-[0_0_15px_rgba(255,0,255,0.1)] group-hover/row:shadow-[0_0_20px_rgba(255,0,255,0.3)] transition-all">
                  {s.minutes}М
                </span>
              </td>
              <td class="p-6 text-right">
                <button 
                  onclick={`deleteSession('${s.id}')`}
                  class="p-2 text-white/20 hover:text-red-500 hover:bg-red-500/10 rounded-lg transition-all transform hover:scale-125 focus:outline-none"
                  title="Удалить запись"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                </button>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</section>

<script is:inline>
  window.deleteSession = async (id) => {
    if (!confirm('Вы действительно хотите удалить эту запись энергии? Это действие необратимо.')) return;
    
    try {
      const res = await fetch(`/api/sessions/${id}`, { method: 'DELETE' });
      if (res.ok) {
        document.getElementById(`session-${id}`).style.opacity = '0';
        setTimeout(() => {
          window.location.reload();
        }, 500);
      } else {
        alert('Ошибка удаления: ' + res.statusText);
      }
    } catch (err) {
      alert('Сбой связи: ' + err.message);
    }
  }
</script>
    </table>
  </div>
</section>

<style>
  @keyframes scan {
    0% { top: 0%; }
    100% { top: 100%; }
  }
</style>
