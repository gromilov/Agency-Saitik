---
interface Props {
  currentFund: number;
  targetFund: number;
  label: string;
}

const { currentFund, targetFund, label } = Astro.props;
const percentage = Math.min(100, Math.round((currentFund / targetFund) * 100));
---

<div class="relative p-6 bg-white/[0.02] border border-white/5 rounded-3xl overflow-hidden group">
  <div class="absolute inset-0 bg-gradient-to-r from-[#00ff9f]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
  
  <div class="relative z-10">
    <div class="flex justify-between items-end mb-4">
      <div>
        <span class="text-[10px] uppercase tracking-[0.4em] text-[#00ff9f] font-black italic block mb-2">МАТЕРИАЛИЗАЦИЯ_СТАТУС</span>
        <h3 class="text-2xl font-bold text-white tracking-tighter uppercase italic">{label}</h3>
      </div>
      <div class="text-right">
        <span class="text-3xl font-black text-white glow-text">{currentFund.toLocaleString()}</span>
        <span class="text-xs text-white/40 font-mono ml-2">/ {targetFund.toLocaleString()} RUB</span>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="h-3 bg-white/5 rounded-full overflow-hidden border border-white/10 p-[2px]">
      <div 
        class="h-full bg-gradient-to-r from-[#00ff9f] to-[#00f3ff] rounded-full shadow-[0_0_15px_#00ff9f] transition-all duration-1000 ease-out" 
        style={`width: ${percentage}%`}
      >
        <div class="w-full h-full bg-[url('/grid.svg')] opacity-30"></div>
      </div>
    </div>
    
    <div class="mt-4 flex justify-between items-center text-[10px] font-mono uppercase tracking-widest">
      <span class={percentage >= 100 ? "text-[#00ff9f]" : "text-white/20"}>
        {percentage >= 100 ? "ЦЕЛЬ_ДОСТИГНУТА" : "ПОТОК_АКТИВЕН"}
      </span>
      <span class="text-[#00ff9f] glow-text">{percentage}%</span>
    </div>
  </div>
</div>
