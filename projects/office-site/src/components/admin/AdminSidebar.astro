---
import SyndicateLogo from '../ui/SyndicateLogo.astro';

interface Props {
  activeTab?: 'dashboard' | 'content' | 'finance' | 'analytics' | 'security';
}

const { activeTab = 'dashboard' } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'ГЛАВНАЯ', icon: '🏠', href: '/admin' },
  { id: 'content', label: 'КОНТЕНТ', icon: '📝', href: '/admin/kashlak' },
  { id: 'comments', label: 'КОММЕНТАРИИ', icon: '💬', href: '/admin/kashlak/comments' },
  { id: 'stories', label: 'СТОРИС', icon: '📹', href: '/admin/stories' },
  { id: 'finance', label: 'ФИНАНСЫ', icon: '💎', href: '#', locked: true },
  { id: 'analytics', label: 'АНАЛИТИКА', icon: '📊', href: '#', locked: true },
  { id: 'security', label: 'ЗАЩИТА', icon: '🛡️', href: '#', locked: true },
];
---

<aside class="fixed left-0 top-0 h-full w-20 md:w-64 bg-[#030308]/90 backdrop-blur-md border-r border-white/5 z-[100] transition-all duration-500 group/sidebar overflow-hidden hover:w-64">
  <div class="flex flex-col h-full p-4 md:p-6">
    <!-- Logo area -->
    <a href="/" class="flex items-center gap-4 mb-12 px-2 hover:opacity-80 transition-opacity shrink-0">
      <div class="w-10 h-10 rounded-xl bg-black/40 border border-white/10 flex items-center justify-center shadow-[0_0_20px_rgba(0,255,159,0.1)] shrink-0 relative overflow-hidden group/logo">
        <div class="absolute inset-0 bg-gradient-to-tr from-[#00ff9f]/20 to-[#ff00ff]/20 opacity-0 group-hover/logo:opacity-100 transition-opacity"></div>
        <SyndicateLogo size="24" id="sidebar-logo" />
      </div>
      <div class="opacity-0 group-hover/sidebar:opacity-100 md:opacity-100 transition-all duration-500 whitespace-nowrap overflow-hidden">
        <span class="text-white font-black tracking-[-0.05em] text-xl block leading-none">СИНДИКАТ</span>
        <span class="text-[#00ff9f] text-[7px] uppercase tracking-[0.2em] font-bold mt-1 block opacity-80">ЦЕНТР_УПРАВЛЕНИЯ</span>
      </div>
    </a>

    <!-- Nav Items -->
    <nav class="flex-1 space-y-2">
      {navItems.map(item => (
        <a 
          href={item.href}
          class:list={[
            "flex items-center gap-4 p-4 rounded-2xl transition-all duration-300 relative group/item overflow-hidden",
            activeTab === item.id ? "bg-white/5 text-[#00ff9f]" : "text-white/40 hover:text-white hover:bg-white/[0.02]",
            item.locked && "cursor-not-allowed opacity-50"
          ]}
        >
          {activeTab === item.id && (
            <div class="absolute left-0 top-1/4 bottom-1/4 w-1 bg-[#00ff9f] rounded-full shadow-[0_0_15px_#00ff9f]"></div>
          )}
          
          <span class="text-xl shrink-0">{item.icon}</span>
          <span class="opacity-0 group-hover/sidebar:opacity-100 md:opacity-100 transition-opacity duration-500 font-bold tracking-[0.2em] text-[10px] whitespace-nowrap uppercase">
            {item.label}
          </span>

          {item.locked && (
            <span class="ml-auto opacity-0 group-hover/sidebar:opacity-60 md:opacity-60 text-[9px] font-black border border-white/20 px-2 py-0.5 rounded-sm uppercase tracking-tighter">LOCKED</span>
          )}
          
          <!-- Hover effect decor -->
          <div class="absolute inset-0 bg-gradient-to-r from-white/[0.02] to-transparent translate-x-[-100%] group-hover/item:translate-x-0 transition-transform duration-500"></div>
        </a>
      ))}
    </nav>

    <!-- Footer Status -->
    <div class="mt-auto px-2 opacity-0 group-hover/sidebar:opacity-100 md:opacity-100 transition-opacity duration-500">
        <div class="p-4 rounded-2xl bg-white/[0.02] border border-white/5 text-center">
            <span class="text-[8px] text-white/20 block mb-1 uppercase tracking-widest font-black">System_Uptime</span>
            <span class="text-[10px] text-[#00ff9f] font-mono font-bold animate-pulse">99.9%_STABLE</span>
        </div>
    </div>
  </div>
</aside>

<style>
  /* Custom scrollbar for sidebar if needed */
  aside::-webkit-scrollbar {
    width: 2px;
  }
  aside::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
  }
</style>
