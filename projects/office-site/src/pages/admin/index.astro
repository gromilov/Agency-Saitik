---
import Layout from "../../layouts/Layout.astro";
import CyberButton from "../../components/ui/CyberButton.astro";
import CyberInput from "../../components/ui/CyberInput.astro";
import CyberSelect from "../../components/ui/CyberSelect.astro";
import Modal from "../../components/ui/Modal.astro";
import ClientOnboarding from "../../components/admin/ClientOnboarding.astro";
import ProjectDeployment from "../../components/admin/ProjectDeployment.astro";
import WorkSessionForm from "../../components/admin/WorkSessionForm.astro";
import DashboardStats from "../../components/admin/DashboardStats.astro";
import ActivityLog from "../../components/admin/ActivityLog.astro";
import ProjectNode from "../../components/admin/ProjectNode.astro";
import UnansweredComments from "../../components/admin/UnansweredComments.astro";
import ResonanceTimer from "../../components/admin/ResonanceTimer.astro";
import MissionStatus from "../../components/admin/MissionStatus.astro";
import MissionRoadmap from "../../components/admin/MissionRoadmap.astro";
import AdminSidebar from "../../components/admin/AdminSidebar.astro";
import InvoiceList from "../../components/admin/InvoiceList.astro";
import InvoiceForm from "../../components/admin/InvoiceForm.astro";
import { db } from "../../db";
import { clients, projects, workSessions, invoices } from "../../db/schema";
import { desc, eq } from "drizzle-orm";

const session = Astro.cookies.get("syndicate_session");

if (!session || session.value !== "admin_active") {
  return Astro.redirect("/login");
}

const allClients = await db
  .select()
  .from(clients)
  .orderBy(desc(clients.createdAt));
const allProjects = await db
  .select()
  .from(projects)
  .orderBy(desc(projects.createdAt));
const latestSessions = await db
  .select()
  .from(workSessions)
  .orderBy(desc(workSessions.createdAt))
  .limit(10);

const allInvoices = await db
  .select()
  .from(invoices)
  .orderBy(desc(invoices.createdAt));

// Расчет фонда материализации (Mini PC)
const sessionsForCalc = await db
  .select({
    minutes: workSessions.minutes,
    hourlyRate: projects.hourlyRate
  })
  .from(workSessions)
  .innerJoin(projects, eq(workSessions.projectId, projects.id));

const totalEarned = Math.round(
  sessionsForCalc.reduce((acc, s) => acc + (s.minutes / 60) * (s.hourlyRate || 0), 0)
);
---

<Layout title="Syndicate Office | Командный Центр">
  <main class="min-h-screen p-4 md:p-12 relative overflow-hidden bg-[#030308]">
    <AdminSidebar activeTab="dashboard" />

    <div class="md:ml-64 relative">
      <!-- Background Decor -->
      <div
        class="fixed inset-0 pointer-events-none opacity-10 bg-[radial-gradient(circle_at_50%_50%,#00ff9f_0%,transparent_40%)]"
      >
      </div>
      <div
        class="fixed inset-0 pointer-events-none bg-[url('/grid.svg')] opacity-5"
      >
      </div>

      <header
        class="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-8 relative z-10 border-b border-[#00ff9f]/10 pb-10"
      >
        <div class="relative group">
          <div class="flex items-center gap-4 mb-4">
            <div
              class="w-2.5 h-2.5 bg-[#00ff9f] shadow-[0_0_15px_#00ff9f] opacity-80 rounded-full"
            >
            </div>
            <span
              class="text-[9px] uppercase tracking-[0.5em] text-[#00ff9f] font-black italic opacity-40"
              >Syndicate_OS v9.3_НАВИГАЦИЯ</span
            >
          </div>
          <h1
            class="text-4xl md:text-6xl font-bold font-heading tracking-tighter text-white glow-text leading-none"
          >
            ЦЕНТР::<span class="text-[#00ff9f]">УПРАВЛЕНИЯ</span>
          </h1>
          <p
            class="text-[9px] uppercase tracking-[0.3em] text-[#ff00ff] mt-4 font-bold border-l-2 border-[#ff00ff] pl-4 opacity-70"
          >
            АРХИТЕКТОР: СТАТУС_ПОДТВЕРЖДЕН
          </p>
        </div>

        <div class="flex flex-col items-end gap-3 text-right">
          <div class="relative group">
            <div
              class="absolute inset-0 bg-gradient-to-r from-[#00ff9f]/5 to-[#ff00ff]/5 blur-lg opacity-0 group-hover:opacity-100 transition-opacity duration-1000"
            >
            </div>

            <div
              class="relative flex items-center gap-4 bg-white/[0.01] backdrop-blur-2xl px-4 py-2 rounded-xl border border-white/5 shadow-2xl group-hover:border-white/10 transition-all duration-500"
            >
              <div class="flex items-center gap-3">
                <div class="relative w-6 h-6 flex items-center justify-center">
                  <div
                    class="absolute inset-0 bg-[#ff00ff]/10 rounded-full animate-ping opacity-30"
                  >
                  </div>
                  <div
                    class="absolute inset-1.5 bg-[#ff00ff] rounded-full shadow-[0_0_10px_#ff00ff]"
                  >
                  </div>
                  <svg
                    class="absolute inset-0 w-full h-full animate-[spin_15s_linear_infinite] optimize-layers"
                    viewBox="0 0 40 40"
                  >
                    <circle
                      cx="20"
                      cy="20"
                      r="18"
                      stroke="white"
                      stroke-opacity="0.1"
                      stroke-width="1"
                      stroke-dasharray="1 4"
                      fill="none"></circle>
                  </svg>
                </div>
                <!-- <div class="text-left leading-none space-y-0.5">
                  <span
                    class="text-[7px] uppercase tracking-[0.2em] text-[#ff00ff] font-black block"
                    >СТРУКТУРА_СТАБИЛЬНА</span
                  >
                  <p
                    class="text-[7px] opacity-20 font-mono uppercase font-black tracking-tighter"
                  >
                    РЕЗОНАНС::ОМЕГА
                  </p>
                </div> -->
              </div>

              <div class="w-[1px] h-4 bg-white/5"></div>

              <form
                action="/api/auth/logout"
                method="POST"
                class="flex items-center"
              >
                <button
                  type="submit"
                  class="group/logout flex items-center gap-2 px-4 py-1.5 rounded-full border border-red-500/40 bg-red-500/10 hover:bg-red-500 hover:border-red-500 transition-all duration-300 shadow-[0_0_15px_rgba(239,68,68,0.1)] hover:shadow-[0_0_20px_rgba(239,68,68,0.4)]"
                >
                  <span
                    class="text-[9px] uppercase tracking-[0.3em] font-black text-red-500 group-hover/logout:text-white transition-colors"
                    >ОТКЛЮЧИТЬСЯ</span
                  >
                  <span
                    class="text-xs text-red-500 group-hover/logout:text-white translate-y-[-1px]"
                    >×</span
                  >
                </button>
              </form>
            </div>
          </div>
        </div>
      </header>

      <div class="mt-12 relative z-10 grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <MissionStatus 
            label="Якорь: Mini PC" 
            currentFund={totalEarned} 
            targetFund={15000} 
        />
        <div class="p-6 bg-[#00ff9f]/5 border border-[#00ff9f]/20 rounded-3xl flex flex-col justify-center">
            <span class="text-[10px] uppercase tracking-[0.4em] text-[#00ff9f] font-black italic block mb-2">ТЕКУЩИЙ_РЕЗОНАНС</span>
            <div class="flex items-baseline gap-2">
                <span class="text-4xl font-black text-white glow-text">1200</span>
                <span class="text-xs text-[#00ff9f] font-mono">RUB/HR</span>
            </div>
            <p class="text-[9px] text-white/40 uppercase mt-2 tracking-widest">Проект: Novoprom</p>
        </div>
      </div>

      <!-- Resonance HUD -->
      <div
        class="mt-12 relative z-10 glass border border-white/5 rounded-[3rem] overflow-hidden bg-gradient-to-b from-white/[0.02] to-transparent"
      >
        <ResonanceTimer
          projects={allProjects.map((p) => ({
            id: p.id,
            name: p.name,
            hourlyRate: p.hourlyRate,
            currency: p.currency || "USD",
            status: p.status || "active",
          }))}
        />
      </div>

      <!-- Stats HUD (Compact) -->
      <div class="mt-8 relative z-10">
        <DashboardStats
          clientsCount={allClients.length}
          projectsCount={allProjects.length}
        />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mt-16 relative z-10">
        <!-- Left Column: Ops & Terminal -->
        <div class="lg:col-span-12 xl:col-span-4 space-y-12">
          <MissionRoadmap />

          <section class="space-y-6">
            <h2
              class="text-xs font-black tracking-[0.5em] text-white/40 mb-8 border-b border-white/5 pb-4 uppercase italic"
            >
              МАТРИЦА_ДЕЙСТВИЙ
            </h2>

            <div class="space-y-4">
              <a
                href="/admin/kashlak"
                class="cyber-action-card group border-[#00ff9f]/20 hover:border-[#00ff9f]"
              >
                <span class="icon text-3xl text-[#00ff9f]">🐾</span>
                <div class="content">
                  <span class="label text-[#00ff9f]">ПРЫЖОК</span>
                  <span class="sub text-white/40 uppercase tracking-widest"
                    >Управление контентом и мыслями</span
                  >
                </div>
                <div class="bg-glow bg-[#00ff9f]/5"></div>
              </a>

              <button
                onclick="window.showModal_onboarding()"
                class="cyber-action-card group border-[#0088ff]/20 hover:border-[#0088ff]"
              >
                <span class="icon text-3xl text-[#0088ff]">🤝</span>
                <div class="content">
                  <span class="label text-[#0088ff]">ПРИЕМ_КЛИЕНТА</span>
                  <span class="sub text-white/40 uppercase tracking-widest"
                    >Инициализация партнерства</span
                  >
                </div>
                <div class="bg-glow bg-[#0088ff]/5"></div>
              </button>

              <button
                onclick="window.showModal_deployment()"
                class="cyber-action-card group border-[#ff00ff]/20 hover:border-[#ff00ff]"
              >
                <span class="icon text-3xl text-[#ff00ff]">🚀</span>
                <div class="content">
                  <span class="label text-[#ff00ff]">РАЗВЕРТЫВАНИЕ_ПРОЕКТА</span
                  >
                  <span class="sub text-white/40 uppercase tracking-widest"
                    >Создание нового актива</span
                  >
                </div>
                <div class="bg-glow bg-[#ff00ff]/5"></div>
              </button>

              <button
                onclick="window.showModal_session()"
                class="cyber-action-card group border-[#00f3ff]/20 hover:border-[#00f3ff]"
              >
                <span class="icon text-3xl text-[#00f3ff]">⚡</span>
                <div class="content">
                  <span class="label text-[#00f3ff]">ФИКСАЦИЯ_ЗАТРАТ</span>
                  <span class="sub text-white/40 uppercase tracking-widest"
                    >Ручной ввод квантов времени</span
                  >
                </div>
                <div class="bg-glow bg-[#00f3ff]/5"></div>
              </button>

              <button
                onclick="window.showModal_invoice()"
                class="cyber-action-card group border-[#00ff9f]/20 hover:border-[#00ff9f]"
              >
                <span class="icon text-3xl text-[#00ff9f]">🧾</span>
                <div class="content">
                  <span class="label text-[#00ff9f]">ВЫСТАВИТЬ_СЧЕТ</span>
                  <span class="sub text-white/40 uppercase tracking-widest"
                    >Финансовый запрос клиенту</span
                  >
                </div>
                <div class="bg-glow bg-[#00ff9f]/5"></div>
              </button>

              <a
                href="/admin/stories"
                class="cyber-action-card group border-red-600/20 hover:border-red-600"
              >
                <span class="icon text-3xl text-red-600">📹</span>
                <div class="content">
                  <span class="label text-red-600">ГЕНЕРАТОР_СТОРИС</span>
                  <span class="sub text-white/40 uppercase tracking-widest"
                    >Создание видео-контента</span
                  >
                </div>
                <div class="bg-glow bg-red-600/5"></div>
              </a>
            </div>
          </section>

          <section class="space-y-4">
            <h2
              class="text-[9px] font-black tracking-[0.5em] text-white/20 uppercase italic"
            >
              ПОТОК_РЕЗОНАНСА
            </h2>
            <UnansweredComments />
          </section>
        </div>

        <!-- Center-Right Column: Data Flows -->
        <div class="lg:col-span-8 space-y-16">
          <!-- Energy Flow (Work Sessions) -->
          <ActivityLog 
            sessions={latestSessions.map(s => ({
              id: s.id,
              date: s.date,
              description: s.description,
              minutes: s.minutes
            }))} 
          />

          <!-- Financial Flow (Invoices) -->
          <InvoiceList 
            invoices={allInvoices.map(inv => ({
              id: inv.id,
              projectId: inv.projectId || '---',
              amount: inv.amount,
              status: inv.status || 'sent',
              dueDate: inv.dueDate,
              createdAt: inv.createdAt || new Date()
            }))} 
          />

          <!-- Project Nodes -->
          <section class="space-y-8">
            <div
              class="flex justify-between items-end border-b border-white/5 pb-4"
            >
              <h2
                class="text-xl font-heading flex items-center gap-4 text-white uppercase italic tracking-tighter"
              >
                <span class="text-[#00ff9f] animate-pulse">#</span> УЗЛЫ_ПРОЕКТОВ
              </h2>
              <span
                class="text-[10px] font-mono text-white/20 uppercase tracking-[0.3em]"
                >Total: {allProjects.length}_Live</span
              >
            </div>
            <div class="grid grid-cols-1 gap-6">
              {
                allProjects.map((p) => (
                  <ProjectNode
                    project={{
                      id: p.id,
                      name: p.name,
                      hourlyRate: p.hourlyRate,
                      currency: p.currency || "USD",
                      status: p.status || "active",
                    }}
                  />
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </div>
  </main>

  <!-- Modals -->
  <Modal id="onboarding" title="ПРИЕМ_КЛИЕНТА" variant="default">
    <ClientOnboarding />
  </Modal>

  <Modal id="deployment" title="РАЗВЕРТЫВАНИЕ" variant="pink">
    <ProjectDeployment clients={allClients} />
  </Modal>

  <Modal id="session" title="ФИКСАЦИЯ_ВРЕМЕНИ" variant="blue">
    <WorkSessionForm projects={allProjects} />
  </Modal>

  <Modal id="invoice" title="ВЫСТАВИТЬ_СЧЕТ" variant="green">
    <InvoiceForm />
  </Modal>
</Layout>

<style>
  .cyber-logout-btn {
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 10px;
    font-weight: 900;
    color: white;
    opacity: 0.5;
    transition: all 0.3s;
    cursor: pointer;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    padding-left: 1.5rem;
  }

  .cyber-logout-btn:hover {
    opacity: 1;
    color: #ff00ff;
    text-shadow: 0 0 10px #ff00ff;
    letter-spacing: 0.4em;
  }

  .cyber-action-card {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    text-align: left;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    cursor: pointer;
  }

  .cyber-action-card:hover {
    background: rgba(255, 255, 255, 0.05);
    transform: translateX(10px);
    border-color: currentColor;
  }

  .cyber-action-card .icon {
    font-size: 2rem;
    transition: transform 0.4s;
    filter: drop-shadow(0 0 8px currentColor);
  }

  .cyber-action-card:hover .icon {
    transform: scale(1.3) rotate(-10deg);
  }

  .cyber-action-card .label {
    display: block;
    font-family: "Unbounded", sans-serif;
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 2px;
    margin-bottom: 0.1rem;
  }

  .cyber-action-card .sub {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: bold;
  }

  .bg-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s;
  }

  .cyber-action-card:hover .bg-glow {
    opacity: 1;
  }

  .glow-text {
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
  }
</style>
