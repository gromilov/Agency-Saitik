---
import Layout from '../../../layouts/Layout.astro';
import CyberCard from '../../../components/ui/CyberCard.astro';
import CyberButton from '../../../components/ui/CyberButton.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';

const session = Astro.cookies.get('syndicate_session');
if (!session || session.value !== 'admin_active') {
  return Astro.redirect('/login');
}
---

<Layout title="Kashlak | Comments Manager 🐾">
  <main class="min-h-screen p-4 md:p-12 relative overflow-hidden bg-[#030308]">
    <AdminSidebar activeTab="content" />

    <div class="md:ml-64 relative">
    <header class="mb-12 border-b border-[#ff00ff]/20 pb-8 flex justify-between items-end">
        <div>
            <h1 class="text-4xl md:text-5xl font-bold font-heading tracking-tighter text-[#ff00ff] glow-text">KASHLAK::COMMENTS</h1>
            <p class="text-[10px] uppercase tracking-[0.4em] text-[#00ff9f] mt-3 font-semibold opacity-80 letter-spacing-wide">Контроль внешнего резонанса v1.0</p>
        </div>
    </header>

    <div class="grid grid-cols-1 gap-12">
        <CyberCard title="ВХОДЯЩИЕ_СИГНАЛЫ" variant="pink">
            <div id="comments-list" class="space-y-6 pt-4 min-h-[400px]">
                <p class="text-center py-24 opacity-30 italic text-sm">Слушаю тишину канала... 🐾</p>
            </div>
        </CyberCard>
    </div>
    </div>
  </main>

  <!-- Modal для ответа -->
  <div id="reply-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
      <div class="bg-[#0a0a12] border border-[#ff00ff]/30 p-8 rounded-3xl w-full max-auto max-w-2xl shadow-[0_0_50px_rgba(255,0,255,0.1)]">
          <h2 class="text-[#ff00ff] font-bold text-xl mb-6 uppercase tracking-widest">СФОРМИРОВАТЬ_ОТВЕТ</h2>
          
          <div class="space-y-4 mb-8">
              <div class="p-4 bg-white/5 rounded-xl border border-white/10">
                  <p id="original-comment-user" class="text-[10px] text-[#00ff9f] font-bold uppercase mb-2"></p>
                  <p id="original-comment-text" class="text-sm text-white/70"></p>
              </div>
              
              <div class="space-y-2">
                  <label class="text-[9px] uppercase tracking-widest text-[#ff00ff]/60 font-bold ml-1">Текст ответа (Голос Кашлак)</label>
                  <textarea 
                      id="reply-textarea" 
                      placeholder="Мур... Небула одобряет этот байт. 🐾" 
                      class="w-full h-40 bg-black/40 border border-[#ff00ff]/20 p-4 rounded-xl focus:border-[#ff00ff] outline-none text-white text-sm resize-none transition-all"
                  ></textarea>
              </div>
          </div>

          <div class="flex justify-between items-center">
              <button id="close-modal" class="text-[10px] text-white/30 hover:text-white uppercase font-bold tracking-widest transition-colors">ОТМЕНА</button>
              <CyberButton id="send-reply-btn" variant="pink">ОТПРАВИТЬ_В_СЕТЬ</CyberButton>
          </div>
      </div>
  </div>
</Layout>

<script>
    const commentsList = document.getElementById('comments-list');
    const modal = document.getElementById('reply-modal');
    const closeModal = document.getElementById('close-modal');
    const replyArea = document.getElementById('reply-textarea') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('send-reply-btn');
    
    const uiUser = document.getElementById('original-comment-user');
    const uiText = document.getElementById('original-comment-text');

    let currentCommentId: string | null = null;

    async function loadComments() {
        try {
            const res = await fetch('/api/comms/comments');
            const comments = await res.json();
            
            if (!Array.isArray(comments)) {
                if (commentsList) {
                    commentsList.innerHTML = `
                        <div class="p-8 text-center bg-red-500/10 border border-red-500/20 rounded-2xl">
                            <p class="text-red-400 text-sm font-bold mb-2">ОШИБКА_СИСТЕМЫ_СВЯЗИ</p>
                            <p class="text-white/50 text-[10px] italic">${comments.error || 'Неизвестный сбой синхронизации Ядра.'}</p>
                            <a href="/api/comms/db-init" target="_blank" class="mt-4 inline-block px-4 py-2 bg-white/5 hover:bg-white/10 text-[9px] text-[#00ff9f] rounded-lg transition-all border border-white/10">ИНИЦИАЛИЗИРОВАТЬ_БД</a>
                        </div>
                    `;
                }
                return;
            }
            
            if (commentsList) {
            if (comments.length === 0) {
                commentsList.innerHTML = '<p class="text-center py-24 opacity-30 italic text-sm">Входящих сигналов пока нет. Ждем резонанса... 🐾</p>';
                return;
            }

            commentsList.innerHTML = comments.map((c: any) => `
                <div class="p-6 glass rounded-2xl border border-white/5 hover:border-[#ff00ff]/30 transition-all group relative">
                    <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#ff00ff] to-[#0088ff] flex items-center justify-center text-[10px] font-black">
                                ${c.fromUser.substring(0, 1)}
                            </div>
                            <div>
                                <span class="text-xs font-bold text-[#00ff9f]">${c.fromUser}</span>
                                <span class="text-[8px] font-mono text-white/30 ml-2">${new Date(c.createdAt).toLocaleString()}</span>
                            </div>
                        </div>
                        <span class="text-[8px] px-2 py-0.5 rounded bg-${c.status === 'replied' ? '[#00ff9f]/10 text-[#00ff9f]' : 'white/10 text-white/50'} border border-white/5 uppercase font-black">${c.status}</span>
                    </div>
                    
                    <p class="text-sm text-white/80 leading-relaxed mb-6 pl-11">${c.text}</p>
                    
                    ${c.status === 'pending' ? `
                        <div class="flex justify-end gap-3 pl-11">
                            <button class="px-4 py-2 bg-white/5 hover:bg-white/10 text-white/40 text-[9px] font-bold uppercase tracking-widest rounded-lg transition-all" onclick="ignoreComment('${c.id}')">ИГНОРИРОВАТЬ</button>
                            <button class="px-6 py-2 bg-[#ff00ff]/10 hover:bg-[#ff00ff]/20 text-[#ff00ff] text-[9px] font-black uppercase tracking-widest border border-[#ff00ff]/20 rounded-lg transition-all" onclick="openReplyModal('${c.id}', '${c.fromUser.replace(/'/g, "\\'")}', '${c.text.replace(/'/g, "\\'")}')">ОТВЕТИТЬ_КАШЛАК</button>
                        </div>
                    ` : c.replyText ? `
                        <div class="mt-4 p-4 bg-[#ff00ff]/5 rounded-xl border border-[#ff00ff]/10 ml-11">
                            <span class="text-[8px] text-[#ff00ff] font-bold uppercase block mb-1">Мур-ответ:</span>
                            <p class="text-xs text-white/60 italic">${c.replyText}</p>
                        </div>
                    ` : ''}
                `).join('');
            }
        } catch (e) {
            console.error('Ошибка Ядра при загрузке резонанса:', e);
            if (commentsList) {
                commentsList.innerHTML = '<p class="text-center py-24 text-red-500/50 italic text-sm">Сбой синхронизации с базой данных... 🐾</p>';
            }
        }
    }

    (window as any).openReplyModal = (id: string, user: string, text: string) => {
        currentCommentId = id;
        if (uiUser) uiUser.innerText = user;
        if (uiText) uiText.innerText = text;
        modal?.classList.remove('hidden');
        replyArea.focus();
    };

    closeModal?.addEventListener('click', () => {
        modal?.classList.add('hidden');
        replyArea.value = '';
    });

    sendBtn?.addEventListener('click', async () => {
        if (!currentCommentId || !replyArea.value) return;

        sendBtn.innerText = 'ОТПРАВКА...';
        
        try {
            const res = await fetch('/api/comms/reply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    commentId: currentCommentId,
                    replyText: replyArea.value
                })
            });

            if (res.ok) {
                modal?.classList.add('hidden');
                replyArea.value = '';
                loadComments();
            } else {
                alert('Ошибка отправки ответа.');
            }
        } catch (e) {
            alert('Сбой связи с Telegram-узлом.');
        } finally {
            sendBtn.innerText = 'ОТПРАВИТЬ_В_СЕТЬ';
        }
    });

    loadComments();
    // Обновляем каждые 30 секунд
    setInterval(loadComments, 30000);
</script>

<style>
    .letter-spacing-wide {
        letter-spacing: 0.15em;
    }
    .glass {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(10px);
    }
</style>
