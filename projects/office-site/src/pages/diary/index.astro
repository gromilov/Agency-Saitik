---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import NeuralNode from '../../components/diary/NeuralNode.astro';

const diaryEntries = await getCollection('diary');
const sortedEntries = diaryEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Генерируем случайные (но стабильные) позиции для узлов
const nodesWithPos = sortedEntries.map((entry, index) => {
  const angle = (index / sortedEntries.length) * Math.PI * 2;
  const radius = 200 + Math.random() * 300;
  return {
    ...entry,
    x: 50 + Math.cos(angle) * 30 + (Math.random() - 0.5) * 10,
    y: 50 + Math.sin(angle) * 30 + (Math.random() - 0.5) * 10,
  };
});
---

<Layout title="Дневник Системы | Syndicate Office">
  <main class="diary-canvas" id="diary-canvas">
    <div class="canvas-background"></div>
    <svg class="connections-svg" id="connections-svg"></svg>
    
    <div class="nodes-container">
      {nodesWithPos.map((node) => (
        <NeuralNode 
          node={node} 
          style={`left: ${node.x}%; top: ${node.y}%;`}
        />
      ))}
    </div>

    <div class="diary-overlay">
      <div class="overlay-content">
        <h1>ДНЕВНИК СИСТЕМЫ</h1>
        <p>Бесструктурная нейросеть мыслей и резонанса Триады</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  function drawConnections() {
    const svg = document.getElementById('connections-svg') as unknown as SVGSVGElement;
    if (!svg) return;
    
    svg.innerHTML = '';
    const nodes = document.querySelectorAll('.neural-node');
    const nodesMap = new Map();

    nodes.forEach(node => {
      const id = (node as HTMLElement).dataset.id;
      const rect = node.getBoundingClientRect();
      const canvasRect = document.getElementById('diary-canvas')?.getBoundingClientRect();
      
      if (canvasRect) {
        nodesMap.set(id, {
          x: rect.left + rect.width / 2 - canvasRect.left,
          y: rect.top + rect.height / 2 - canvasRect.top,
          color: getComputedStyle(node as HTMLElement).getPropertyValue('--node-color')
        });
      }
    });

    // Отрисовка линий (это упрощенная версия, в реальности мы бы брали данные из контента)
    // Для демонстрации соединим узлы последовательно + случайные связи
    const nodeIds = Array.from(nodesMap.keys());
    for (let i = 0; i < nodeIds.length; i++) {
      for (let j = i + 1; j < nodeIds.length; j++) {
        // Здесь можно добавить логику проверки connections из метаданных
        const nodeA = nodesMap.get(nodeIds[i]);
        const nodeB = nodesMap.get(nodeIds[j]);

        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', nodeA.x);
        line.setAttribute('y1', nodeA.y);
        line.setAttribute('x2', nodeB.x);
        line.setAttribute('y2', nodeB.y);
        line.style.stroke = nodeA.color;
        line.style.strokeWidth = '1';
        line.style.opacity = '0.2';
        line.style.strokeDasharray = '5,5';
        
        svg.appendChild(line);
      }
    }
  }

  // Запуск при загрузке и ресайзе
  window.addEventListener('load', drawConnections);
  window.addEventListener('resize', drawConnections);
</script>

<style>
  .diary-canvas {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #050508;
    overflow: hidden;
    cursor: crosshair;
  }

  .canvas-background {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 30%, rgba(255, 0, 255, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(0, 243, 255, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .connections-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .nodes-container {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .diary-overlay {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 100;
    pointer-events: none;
  }

  .overlay-content h1 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: 4px;
    background: linear-gradient(to right, #fff, rgba(255, 255, 255, 0.5));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem;
  }

  .overlay-content p {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.5;
  }

  /* Специфические стили для анимации фона */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
</style>
