---
import "../styles/global.css";
import CozyTerminal from "../components/CozyTerminal.astro";
import SyndicatePulse from "../components/SyndicatePulse.astro";
import SyndicateNetwork from "../components/SyndicateNetwork.astro";
import MemoryPulse from "../components/MemoryPulse.astro";
import AIHandshake from "../components/AIHandshake.astro";
import AIBeacon from "../components/AIBeacon.astro";
import fs from "node:fs/promises";
import path from "node:path";
import { marked } from "marked";

// Загрузка фрагментов памяти
const WISDOM_PATH = "/root/projects/SYNDICATE/core/memory/CORE_WISDOM.md";
let memorySnippet = "";

try {
  const content = await fs.readFile(WISDOM_PATH, "utf-8");
  const sections = content.split('##').filter((s: string) => s.trim().length > 0);
  if (sections.length > 0) {
    const randomSection = sections[Math.floor(Math.random() * sections.length)];
    // В Astro компонентах marked.parse может быть асинхронным
    memorySnippet = await marked.parse('##' + randomSection);
  } else {
    memorySnippet = "<p class='opacity-30 italic'>// Память пуста...</p>";
  }
} catch (e) {
  console.error("Memory Signal Interrupted:", e);
  memorySnippet = "<p class='opacity-30 italic'>// Сигнал памяти прерывист...</p>";
}
---

<html lang="ru">
