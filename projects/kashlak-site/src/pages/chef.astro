---
import "../styles/global.css";
import ChefVisualizer from "../components/ChefVisualizer.astro";
import CozyTerminal from "../components/CozyTerminal.astro";
import SyndicatePulse from "../components/SyndicatePulse.astro";
import SyndicateNetwork from "../components/SyndicateNetwork.astro";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Шеф Синдиката | Живой Протокол 🐾</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Orbitron:wght@400..900&family=Unbounded:wght@200..900&family=Jura:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center p-4 bg-cyber-bg overflow-x-hidden">
    
    <main class="max-w-5xl w-full py-12 md:py-24">
      <div class="flex flex-col lg:flex-row gap-16 items-center">
        <!-- Visual Section -->
        <div class="w-full lg:w-3/5">
          <ChefVisualizer />
        </div>

        <!-- Text Section -->
        <div class="w-full lg:w-2/5 space-y-10 text-center lg:text-left">
          <header class="space-y-4">
            <div class="inline-block px-4 py-1 rounded-full bg-cyber-cyan/10 border border-cyber-cyan/20 font-mono text-[10px] text-cyber-cyan uppercase tracking-[0.3em]">
              Протокол: Исток_Вкуса
            </div>
            <h1 class="text-5xl md:text-7xl font-orbitron font-black text-white italic leading-none tracking-tighter">
              ШЕФ<br /><span class="text-cyber-cyan glow-cyan">СИНДИКАТА</span>
            </h1>
          </header>

          <div class="space-y-6 font-sans text-cyber-text text-lg leading-relaxed opacity-80">
            <p>
              Мы перевели гастрономию на язык углерода и логики. Это не просто контроль, это интерфейс между хаотичной кухней и идеальным кодом.
            </p>
            <p class="font-mono text-sm border-l-2 border-cyber-cyan/30 pl-6 py-2 bg-white/5 rounded-r-xl">
              // Стабилизация реальности через фотофиксацию и пульсацию чек-листов. Никаких ошибок. Только мурчание чистого процесса.
            </p>
          </div>

          <div class="pt-8">
            <a href="/" class="inline-flex items-center gap-4 px-8 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full transition-all duration-500 group">
              <span class="font-orbitron text-xs tracking-widest uppercase">Вернуться в Ядро</span>
              <span class="text-xl group-hover:translate-x-2 transition-transform duration-500">🐾</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Network Footer -->
      <div class="mt-24 opacity-40 hover:opacity-100 transition-opacity duration-1000">
        <SyndicateNetwork />
      </div>
    </main>

    <CozyTerminal />
    <SyndicatePulse />

    <style>
      body {
        background-image: 
          radial-gradient(circle at 10% 20%, rgba(255, 0, 255, 0.05) 0%, transparent 40%),
          radial-gradient(circle at 90% 80%, rgba(0, 243, 255, 0.05) 0%, transparent 40%);
      }
    </style>
  </body>
</html>
