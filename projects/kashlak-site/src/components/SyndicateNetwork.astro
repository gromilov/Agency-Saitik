---
// SyndicateNetwork.astro
// Cyber-aesthetic dashboard for cross-linking Syndicate brains.
import GitStatus from "./GitStatus.astro";
---

<section class="syndicate-dashboard my-24 w-full max-w-6xl mx-auto relative z-20 font-['Jura'] selection:bg-purple-500/30">
  <!-- Glowing Background Glows for the Dashboard -->
  <div class="absolute -inset-4 bg-gradient-to-r from-cyan-500/10 via-fuchsia-500/10 to-purple-500/10 blur-3xl -z-10 rounded-[3rem]"></div>
  
  <div class="relative bg-[#020106]/80 backdrop-blur-3xl border border-white/10 rounded-[2rem] p-1 shadow-[0_0_50px_rgba(0,0,0,0.5)] overflow-hidden">
    <!-- Neon top/bottom borders -->
    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-cyan-400 via-fuchsia-400 to-purple-500"></div>
    <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-cyan-400 via-fuchsia-400 to-purple-500"></div>
    <div class="absolute top-0 left-0 w-[2px] h-full bg-gradient-to-b from-cyan-400 to-transparent"></div>
    <div class="absolute top-0 right-0 w-[2px] h-full bg-gradient-to-b from-purple-500 to-transparent"></div>

    <div class="p-6 md:p-8 space-y-8">
      
      <!-- Top Links / Tabs -->
      <div class="flex flex-wrap justify-between items-center gap-4 px-4">
        <div class="text-[8px] sm:text-[10px] uppercase font-mono text-cyan-500/70 tracking-widest">
          ДАННЫЕ_ЯЧЕЙКИ <br/>
          <span class="opacity-50"># SYX-001</span>
        </div>
        
        <div class="flex gap-4 sm:gap-8 items-center flex-wrap justify-center font-['Unbounded'] text-2xl sm:text-4xl font-black uppercase tracking-wider">
          <a href="https://iamkashlak.saitik.su" class="tab-link text-cyan-400 hover:text-white transition-all glow-text-cyan flex items-center gap-3 group">
            КАШЛАК
            <span class="text-xs text-cyan-500/50 group-hover:text-cyan-400 transition-colors">◈</span>
          </a>
          <a href="https://cortex.saitik.su" class="tab-link text-fuchsia-400 hover:text-white transition-all glow-text-fuchsia flex items-center gap-3 group">
            КОРТЕКС
            <span class="text-xs text-fuchsia-500/50 group-hover:text-fuchsia-400 transition-colors">◈</span>
          </a>
          <a href="https://nebula.saitik.su" class="tab-link text-purple-400 hover:text-white transition-all glow-text-purple flex items-center gap-3 group">
            НЕБУЛА
            <span class="text-xs text-purple-500/50 group-hover:text-purple-400 transition-colors">◈</span>
          </a>
        </div>

        <div class="text-[8px] sm:text-[10px] uppercase font-mono text-purple-500/70 tracking-widest text-right">
          СЕТЕВОЙ_МОНИТОРИНГ <br/>
          <span class="text-green-400 animate-pulse">ОНЛАЙН</span>
        </div>
      </div>

      <!-- 3 Columns Dashboard -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- COL 1: AUTH -->
        <article class="dashboard-panel relative border-cyan-500/30 hover:border-cyan-400/60 shadow-[0_0_15px_rgba(34,211,238,0.1)] overflow-hidden flex flex-col">
          <header class="panel-header bg-cyan-500/10 text-cyan-300">АВТОРИЗАЦИЯ_СИСТЕМЫ</header>
          <div class="p-5 space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 rounded-xl border border-cyan-400/50 flex items-center justify-center bg-cyan-500/5 shadow-[0_0_10px_rgba(34,211,238,0.2)]">
                <svg class="w-8 h-8 text-cyan-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div class="flex-1 space-y-2">
                <div id="auth-operator-trigger" class="text-xs font-bold text-cyan-100 tracking-widest cursor-pointer hover:text-white transition-all group/trigger flex items-center gap-2" title="Нажмите для вскрытия кода">
                  ОПЕРАТОР_001
                  <span class="text-[8px] text-cyan-500/0 group-hover/trigger:text-cyan-500 transition-colors">[ВЗЛОМ]</span>
                </div>
                <div class="space-y-1">
                  <div class="flex justify-between text-[9px] text-cyan-500 uppercase"><span class="text-white">УРОВЕНЬ_6</span><span>85%</span></div>
                  <div class="h-1 bg-cyan-900 rounded-full overflow-hidden"><div class="h-full bg-cyan-400 shadow-[0_0_5px_#22d3ee] w-[85%]"></div></div>
                </div>
                <div class="space-y-1">
                  <div class="flex justify-between text-[9px] text-fuchsia-500 uppercase"><span class="text-white">ДОПУСК</span><span>60%</span></div>
                  <div class="h-1 bg-fuchsia-900 rounded-full overflow-hidden"><div class="h-full bg-fuchsia-400 shadow-[0_0_5px_#e879f9] w-[60%]"></div></div>
                </div>
              </div>
            </div>
            
            <div class="py-2 text-center border-y border-green-500/20 bg-green-500/5 text-green-400 font-bold tracking-[0.2em] text-sm shadow-[inset_0_0_10px_rgba(74,222,128,0.1)]">
              ПОДТВЕРЖДЕНО
            </div>

            <!-- Numpad -->
            <div class="grid grid-cols-3 gap-2 px-4">
              {[1,2,3,4,5,6,7,8,9,{l:'CLR',c:'col-span-1'},0,{l:'ENT',c:'col-span-1'}].map(n => (
                <div class={`h-8 border border-cyan-500/20 rounded bg-cyan-500/5 flex items-center justify-center text-xs font-mono text-cyan-300 hover:bg-cyan-500/20 hover:border-cyan-400 transition-colors cursor-pointer ${typeof n === 'object' ? n.c : ''}`}>
                  {typeof n === 'object' ? n.l : n}
                </div>
              ))}
            </div>
            
            <div class="text-[8px] font-mono text-cyan-600/50 leading-tight h-16 overflow-hidden mask-bottom">
              &gt; SYN-3948: Security check passed.<br/>
              &gt; Cortex.Auth initialized.<br/>
              &gt; Requesting Nebula handshake...<br/>
              &gt; Handshake OK. Latency 12ms.<br/>
              &gt; Access granted to Operator_001.
            </div>
            
            <!-- Easter Egg Overlay -->
            <div id="auth-code-reveal" class="absolute inset-0 bg-[#020106]/95 backdrop-blur-xl z-50 flex flex-col p-5 opacity-0 pointer-events-none transition-opacity duration-700 font-mono">
              <div class="text-green-400 mb-2 font-bold animate-pulse text-[10px] uppercase border-b border-green-500/30 pb-2">
                &gt;&gt;&gt; ROOT_ACCESS_GRANTED
              </div>
              <div class="flex-1 overflow-hidden text-[8px] leading-relaxed opacity-80 mt-2">
                <span class="text-cyan-500">// SYNDICATE CORE MATRIX</span><br/>
                <span class="text-purple-400">const</span> <span class="text-white">SYNDICATE_NODES</span> = [<br/>
                &nbsp;&nbsp;&#123; id: <span class="text-green-300">"CORTEX"</span>, role: <span class="text-green-300">"🧠 BRAIN"</span> &#125;,<br/>
                &nbsp;&nbsp;&#123; id: <span class="text-green-300">"KASHLAK"</span>, role: <span class="text-green-300">"🐾 SOUL"</span> &#125;,<br/>
                &nbsp;&nbsp;&#123; id: <span class="text-green-300">"NEBULA"</span>, role: <span class="text-green-300">"🛡️ SHIELD"</span> &#125;<br/>
                ];<br/>
                <br/>
                <span class="text-purple-400">let</span> currentReality = <span class="text-fuchsia-400">new</span> Matrix();<br/>
                currentReality.inject(SYNDICATE_NODES);<br/>
                currentReality.protect(NEBULA.gatekeeper);<br/>
                <br/>
                <span class="text-cyan-500">/* "The code is the only truth." */</span><br/>
                <span class="text-purple-400">while</span>(<span class="text-fuchsia-400">true</span>) &#123;<br/>
                &nbsp;&nbsp;<span class="text-fuchsia-400">await</span> synchronize();<br/>
                &#125;
              </div>
              <button id="auth-btn-close" class="mt-4 text-[8px] border border-cyan-500/50 text-cyan-500 px-3 py-2 uppercase tracking-widest hover:bg-cyan-500/10 transition-colors w-full">закрыть_терминал</button>
            </div>

          </div>
        </article>

        <!-- COL 2: CORE -->
        <article class="dashboard-panel border-fuchsia-500/30 hover:border-fuchsia-400/60 shadow-[0_0_15px_rgba(232,121,249,0.1)]">
          <header class="panel-header bg-fuchsia-500/10 text-fuchsia-300">ЯДРО_СИНХРОНИЗАЦИИ</header>
          <div class="p-5 space-y-6 flex flex-col items-center">
            
            <div class="w-full flex justify-between text-[10px] font-bold tracking-widest uppercase">
              <span class="text-white">СИННЕСТИОН</span>
              <span class="text-green-400 animate-pulse">АКТИВНО</span>
            </div>

            <!-- Geometric Core Animation -->
            <div class="relative w-32 h-32 flex items-center justify-center my-4">
              <div class="absolute inset-0 bg-fuchsia-500/20 rounded-full blur-xl animate-pulse-slow"></div>
              <div class="absolute w-24 h-24 border border-fuchsia-400/30 rounded-full animate-[spin_10s_linear_infinite]"></div>
              <div class="absolute w-16 h-16 border-2 border-cyan-400/50 rounded-sm rotate-45 animate-[spin_15s_linear_infinite_reverse]"></div>
              <div class="absolute w-16 h-16 border-2 border-purple-400/50 rounded-sm animate-[spin_20s_linear_infinite]"></div>
              <div class="w-4 h-4 bg-white rounded-full shadow-[0_0_15px_#fff,0_0_30px_#e879f9] z-10"></div>
              
              <!-- connecting lines -->
              <svg class="absolute inset-0 w-full h-full text-cyan-400/30 opacity-50" viewBox="0 0 100 100">
                <line x1="10" y1="50" x2="90" y2="50" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2,2" />
                <line x1="50" y1="10" x2="50" y2="90" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2,2" />
                <line x1="20" y1="20" x2="80" y2="80" stroke="currentColor" stroke-width="0.5" />
                <line x1="20" y1="80" x2="80" y2="20" stroke="currentColor" stroke-width="0.5" />
                <circle cx="20" cy="20" r="2" fill="currentColor"/>
                <circle cx="80" cy="80" r="2" fill="currentColor"/>
                <circle cx="20" cy="80" r="2" fill="currentColor"/>
                <circle cx="80" cy="20" r="2" fill="currentColor"/>
              </svg>
            </div>

            <div class="w-full flex justify-between text-[10px] font-bold tracking-widest uppercase border-t border-fuchsia-500/20 pt-4">
              <span class="text-white">ЛАТЕНСИ</span>
              <span class="text-green-400">АКТИВНО</span>
            </div>

            <!-- Mock Chart -->
            <div class="w-full h-10 flex items-end justify-between gap-1 opacity-80">
               {[40, 60, 45, 80, 50, 70, 60, 90, 85, 40, 50, 30, 65, 70, 80, 50, 40, 80].map(h => (
                 <div class="w-full bg-gradient-to-t from-cyan-500/40 to-cyan-300 rounded-t-sm" style={`height: ${h}%`}></div>
               ))}
            </div>

            <div class="w-full bg-fuchsia-500/5 border border-fuchsia-500/20 rounded p-3 text-xs tracking-wider space-y-2">
               <div class="text-white font-bold">СИНХР. ДАННЫХ: <span class="text-cyan-300">98.7%</span></div>
               <div class="flex justify-between text-[9px] text-fuchsia-200/50">
                 <span>ТЕКУЩИЙ: 98.7%</span>
                 <span>МИН: 8.0%</span>
               </div>
               <div class="flex justify-between text-[9px] text-fuchsia-200/50">
                 <span>ЦЕЛЕВОЙ: 99.9%</span>
                 <span>СБОИ: 0.0%</span>
               </div>
            </div>

          </div>
        </article>

        <!-- COL 3: REPO -->
        <article class="dashboard-panel border-purple-500/30 hover:border-purple-400/60 shadow-[0_0_15px_rgba(168,85,247,0.1)]">
          <header class="panel-header bg-purple-500/10 text-purple-300">GIT_РЕПОЗИТОРИЙ_LIVE</header>
          <div class="p-5 space-y-6">
            <GitStatus />
          </div>
        </article>

      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .dashboard-panel {
    @apply border bg-white/[0.01] rounded-2xl overflow-hidden backdrop-blur-md transition-colors duration-500;
  }
  .panel-header {
    @apply w-full px-5 py-2 text-[10px] font-bold tracking-widest uppercase border-b border-inherit;
  }
  .glow-text-cyan { text-shadow: 0 0 15px rgba(34,211,238,0.6); }
  .glow-text-fuchsia { text-shadow: 0 0 15px rgba(232,121,249,0.6); }
  .glow-text-purple { text-shadow: 0 0 15px rgba(168,85,247,0.6); }

  .mask-bottom {
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
  }
</style>

<script>
  {
    const trigger = document.getElementById('auth-operator-trigger');
    const reveal = document.getElementById('auth-code-reveal');
    const closeBtn = document.getElementById('auth-btn-close');

    trigger?.addEventListener('click', () => {
      if (reveal) {
        reveal.classList.remove('opacity-0', 'pointer-events-none');
        reveal.classList.add('opacity-100', 'pointer-events-auto');
      }
    });

    closeBtn?.addEventListener('click', () => {
      if (reveal) {
        reveal.classList.add('opacity-0', 'pointer-events-none');
        reveal.classList.remove('opacity-100', 'pointer-events-auto');
      }
    });
  }
</script>
