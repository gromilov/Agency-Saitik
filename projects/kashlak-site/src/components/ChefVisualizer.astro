---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`chef-container relative ${className}`}>
  <!-- Background Glows -->
  <div class="glow gold absolute top-1/4 left-1/2 -translate-x-1/2 w-32 h-32 bg-[#fff01f]/20 blur-3xl animate-pulse-slow"></div>
  <div class="glow cyan absolute bottom-1/4 left-1/2 -translate-x-1/2 w-48 h-48 bg-[#00f3ff]/10 blur-3xl animate-pulse-slower"></div>

  <div class="visualizer-boundary relative aspect-square max-w-2xl mx-auto overflow-hidden rounded-[40px] border border-white/5 shadow-2xl group">
    <!-- Base Image -->
    <img 
      src="/syndicate-chef.png" 
      alt="Syndicate Chef" 
      class="chef-img w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />

    <!-- Steam Effects (CSS Particles) -->
    <div class="steam-container absolute inset-0 pointer-events-none">
      <div class="steam-particle s1"></div>
      <div class="steam-particle s2"></div>
      <div class="steam-particle s3"></div>
      <div class="steam-particle s4"></div>
    </div>

    <!-- Neon Overlays -->
    <div class="neon-overlay absolute inset-0 pointer-events-none">
      <!-- Top Sensors -->
      <div class="sensor s1 absolute top-[10%] left-[40%] w-4 h-4 rounded-full border border-cyber-cyan/40 bg-cyber-cyan/20 animate-pulse-fast"></div>
      <div class="sensor s2 absolute top-[15%] left-[60%] w-3 h-3 rounded-full border border-cyber-cyan/40 bg-cyber-cyan/20 animate-pulse-medium"></div>
      
      <!-- Visor Pulse -->
      <div class="visor-glow absolute top-[52%] left-[38%] w-[24%] h-[4%] bg-cyber-cyan/30 blur-md animate-glow-pulse"></div>
      
      <!-- Scanline -->
      <div class="scanline absolute top-0 left-0 w-full h-[2px] bg-cyber-cyan/20 blur-[1px] opacity-0 animate-scan"></div>
    </div>

    <!-- Interface Labels -->
    <div class="labels absolute inset-0 flex flex-col justify-between p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
      <div class="top-labels flex justify-between font-mono text-[8px] text-cyber-cyan/50 uppercase tracking-widest">
        <span>sys_online: 100%</span>
        <span>sync_active</span>
      </div>
      <div class="bottom-labels flex justify-between font-mono text-[8px] text-cyber-magenta/50 uppercase tracking-widest">
        <span>heat_optimal: 240°C</span>
        <span>protocol_03_active</span>
      </div>
    </div>
  </div>
</div>

<style>
  .chef-container {
    perspective: 1000px;
  }

  .visualizer-boundary {
    transform-style: preserve-3d;
    transition: transform 0.5s ease-out;
  }

  /* Steam Particles */
  .steam-particle {
    position: absolute;
    bottom: 0;
    width: 60px;
    height: 60px;
    background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(5px);
    opacity: 0;
    animation: steam-rise 8s infinite linear;
  }

  .s1 { left: 10%; animation-delay: 0s; }
  .s2 { left: 40%; animation-delay: 2s; }
  .s3 { left: 70%; animation-delay: 4s; }
  .s4 { left: 85%; animation-delay: 6s; }

  @keyframes steam-rise {
    0% { transform: translateY(0) scale(1); opacity: 0; }
    20% { opacity: 0.6; }
    100% { transform: translateY(-400px) scale(3); opacity: 0; }
  }

  /* Scan Animation */
  @keyframes scan {
    0% { top: 0; opacity: 0; }
    5% { opacity: 0.5; }
    95% { opacity: 0.5; }
    100% { top: 100%; opacity: 0; }
  }
  .animate-scan {
    animation: scan 4s infinite linear;
    animation-delay: 1s;
  }

  /* Glow Pulse */
  @keyframes glow-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }
  .animate-glow-pulse {
    animation: glow-pulse 3s infinite ease-in-out;
  }

  .animate-pulse-slow { animation: pulse 6s infinite ease-in-out; }
  .animate-pulse-slower { animation: pulse 8s infinite ease-in-out; }
  .animate-pulse-fast { animation: pulse 1.5s infinite ease-in-out; }
  .animate-pulse-medium { animation: pulse 2s infinite ease-in-out; }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.2; }
    50% { transform: scale(1.2); opacity: 0.4; }
  }
</style>

<script>
  const boundary = document.querySelector('.visualizer-boundary');
  const container = document.querySelector('.chef-container');

  if (boundary && container) {
    container.addEventListener('mousemove', (e: any) => {
      const rect = container.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      
      const rotateX = (y - centerY) / 20;
      const rotateY = (centerX - x) / 20;
      
      boundary.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    container.addEventListener('mouseleave', () => {
      boundary.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  }
</script>
