---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Cortex AI Subsystem Terminal" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
    </head>
    <body
        class="min-h-screen p-4 sm:p-8 selection:bg-terminal-text selection:text-black"
    >
        <main class="max-w-4xl mx-auto terminal-glow">
            <slot />
        </main>
    </body>
</html>
